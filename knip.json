{
  "$schema": "https://unpkg.com/knip@latest/schema.json",
  "workspaces": {
    ".": {
      "entry": ["mod.ts!", "src/cli.tsx!"],
      "project": ["src/**/*.{ts,tsx,js,jsx}!", "*.ts!"]
    },
    "packages/agent-sdk": {
      "entry": ["src/**/*.test.ts"],
      "project": ["src/**/*.{ts,tsx,js,jsx}!"]
    },
    "packages/bundled-agents": { "project": ["src/**/*.{ts,tsx,js,jsx}!"] },
    "packages/client": { "project": ["**/*.{ts,tsx,js,jsx}!"] },
    "packages/config": { "project": ["**/*.{ts,tsx,js,jsx}!"] },
    "packages/core": { "entry": ["src/**/*.test.ts"], "project": ["src/**/*.{ts,tsx,js,jsx}!"] },
    "packages/cron": { "project": ["src/**/*.{ts,tsx,js,jsx}!"] },
    "packages/diagnostics": { "project": ["src/**/*.{ts,tsx,js,jsx}!"] },
    "packages/fs-watch": { "project": ["**/*.{ts,tsx,js,jsx}!"] },
    "packages/llm": { "entry": ["src/**/*.test.ts"], "project": ["**/*.{ts,tsx,js,jsx}!"] },
    "packages/logger": { "project": ["**/*.{ts,tsx,js,jsx}!"] },
    "packages/mcp": { "project": ["**/*.{ts,tsx,js,jsx}!"] },
    "packages/mcp-server": {
      "entry": ["src/**/*.test.ts"],
      "project": ["src/**/*.{ts,tsx,js,jsx}!"]
    },
    "packages/memory": {
      "entry": ["tests/**/*.test.ts"],
      "project": ["src/**/*.{ts,tsx,js,jsx}!", "tests/**/*.{ts,tsx,js,jsx}!"]
    },
    "packages/notifications": { "project": ["src/**/*.{ts,tsx,js,jsx}!"] },
    "packages/openapi-client": {
      "project": ["**/*.{ts,tsx,js,jsx}!"],
      "entry": ["scripts/build.ts!"]
    },
    "packages/signals": { "project": ["src/**/*.{ts,tsx,js,jsx}!"] },
    "packages/storage": { "project": ["src/**/*.{ts,tsx,js,jsx}!"] },
    "packages/system": { "project": ["agents/**/*.ts!", "workspaces/**/*.ts!"] },
    "packages/utils": { "project": ["**/*.{ts,tsx,js,jsx}!"] },
    "packages/workspace": { "project": ["src/**/*.{ts,tsx,js,jsx}!"] },
    "apps/atlasd": { "project": ["**/*.{ts,tsx,js,jsx}!"] },
    "apps/web-client": {
      "entry": ["src/app.html!", "src/routes/**/*.svelte!", "src/**/*.test.ts"],
      "project": ["src/**/*.{ts,tsx,js,jsx,svelte}!", "*.js!", "*.ts!"],
      "paths": {
        "$lib": ["./src/lib"],
        "$lib/*": ["./src/lib/*"],
        "$app": ["../../node_modules/@sveltejs/kit/src/runtime/app"],
        "$app/*": ["../../node_modules/@sveltejs/kit/src/runtime/app/*"]
      }
    },
    "tools/memory_manager": { "project": ["**/*.{ts,tsx,js,jsx}!"] },
    "tools/evals": {
      "entry": ["agents/**/*.eval.ts!", "lib/*.ts!"],
      "project": ["agents/**/*.{ts,tsx,js,jsx}!", "lib/**/*.{ts,tsx,js,jsx}!"]
    }
  },
  "ignore": [
    "**/*.d.ts",
    "**/vendor/**",
    "**/node_modules/**",
    "**/.svelte-kit/**",
    "**/dist/**",
    "**/build/**",
    "packages/vendor/**",
    "apps/atlas-installer/**"
  ],
  "ignoreDependencies": ["@std/tar"],
  "ignoreBinaries": [],
  "ignoreExportsUsedInFile": { "interface": true, "type": true },
  "rules": {
    "files": "error",
    "dependencies": "error",
    "devDependencies": "warn",
    "unlisted": "error",
    "binaries": "error",
    "unresolved": "error",
    "exports": "error",
    "types": "error",
    "nsExports": "warn",
    "nsTypes": "warn",
    "duplicates": "warn",
    "enumMembers": "warn",
    "classMembers": "off"
  }
}
