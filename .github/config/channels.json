{
  "release": {
    "retention_days": 5,
    "bucket_prefix": "",
    "prerelease": false,
    "draft": true,
    "make_latest": true,
    "version_format": "tag",
    "title_format": "Atlas ({version})",
    "changelog_title": "What's New in {version}"
  },
  "edge": {
    "retention_days": 1,
    "bucket_prefix": "edge/",
    "prerelease": true,
    "draft": false,
    "make_latest": false,
    "version_format": "edge-{date}-{time}-{sha}",
    "title_format": "Atlas (edge: {version})",
    "changelog_title": "Edge Build {version}"
  },
  "nightly": {
    "retention_days": 1,
    "bucket_prefix": "nightly/",
    "prerelease": true,
    "draft": false,
    "make_latest": false,
    "version_format": "nightly-{date}-{sha}",
    "title_format": "Atlas (nightly: {version})",
    "changelog_title": "Nightly Build {version}"
  }
}
