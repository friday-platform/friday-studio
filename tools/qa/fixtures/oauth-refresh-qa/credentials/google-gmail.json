{
  "id": "qa-google-gmail",
  "type": "oauth",
  "provider": "google-gmail",
  "userIdentifier": "qa-user@example.test",
  "label": "qa-user@example.test",
  "isDefault": true,
  "secret": {
    "access_token": "seed_gmail_access_token",
    "refresh_token": "seed_gmail_refresh_token",
    "token_type": "Bearer",
    "expires_at": "$EXPIRES_AT",
