<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- Required Electron runtime permissions -->
  <key>com.apple.security.cs.allow-jit</key>
  <true/>
  <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
  <true/>
  <key>com.apple.security.cs.disable-library-validation</key>
  <true/>

  <!-- Explicitly restrict unnecessary permissions -->
  <key>com.apple.security.personal-information.music-library</key>
  <false/>
  <key>com.apple.security.personal-information.media-library</key>
  <false/>
  <key>com.apple.security.personal-information.music-library-read-only</key>
  <false/>

  <!-- No file access entitlements needed -->

  <!-- Network access for installer downloads (if needed) -->
  <key>com.apple.security.network.client</key>
  <true/>

  <!-- AppleScript/Apple Events entitlements to prevent "access data from other apps" dialog -->
  <key>com.apple.security.automation.apple-events</key>
  <true/>

  <!-- Inherit security scope for child processes (osascript) -->
  <key>com.apple.security.inherit</key>
  <true/>
</dict>
</plist>