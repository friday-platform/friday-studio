{
  "name": "atlas-installer",
  "version": "1.0.0",
  "description": "Cross-platform installer for Atlas CLI",
  "main": "main.js",
  "homepage": "https://atlas.tempestdx.com",
  "author": {
    "name": "Tempest Labs, Inc.",
    "email": "support@tempestdx.com"
  },
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:mac": "electron-builder --mac",
    "build:mac:x64": "electron-builder --mac --x64",
    "build:mac:arm64": "electron-builder --mac --arm64",
    "build:win": "electron-builder --win",
    "build:win:x64": "electron-builder --win --x64",
    "build:win:arm64": "electron-builder --win --arm64",
    "build:linux": "electron-builder --linux",
    "build:linux:x64": "electron-builder --linux --x64",
    "build:linux:arm64": "electron-builder --linux --arm64",
    "build:all": "electron-builder --mac --win --linux",
    "dist": "electron-builder --publish=never",
    "prune-electron": "echo 'Preparing for Electron framework optimization'",
    "cleanup-build": "echo 'Cleaning up build artifacts'",
    "optimize-size": "node optimize-electron.js",
    "test": "deno test --allow-read test-installer.ts",
    "validate": "deno test --allow-read test-installer.ts"
  },
  "license": "PROPRIETARY",
  "devDependencies": {
    "electron": "^37.2.6",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "com.tempestdx.atlas-installer",
    "productName": "Atlas Installer",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "renderer.js",
      "index.html",
      "styles.css",
      "reset.css",
      "preload.js",
      "logo.png",
      "entitlements.mac.plist",
      "atlas-binary/**/*",
      "!**/*.map",
      "!**/node_modules/**/*",
      "!**/.git/**/*",
      "!**/test/**/*",
      "!**/tests/**/*",
      "!**/*.test.js",
      "!**/*.spec.js"
    ],
    "extraResources": [
      {
        "from": "../../EULA.txt",
        "to": "EULA.txt"
      }
    ],
    "asar": true,
    "asarUnpack": [
      "atlas-binary/**/*"
    ],
    "electronLanguages": [
      "en"
    ],
    "mac": {
      "target": "zip",
      "category": "public.app-category.developer-tools",
      "icon": "icons/icon.icns",
      "notarize": true,
      "hardenedRuntime": true,
      "entitlements": "entitlements.mac.plist",
      "entitlementsInherit": "entitlements.mac.plist",
      "minimumSystemVersion": "10.15.0",
      "helperBundleId": null,
      "extendInfo": {
        "NSBluetoothAlwaysUsageDescription": false,
        "NSBluetoothPeripheralUsageDescription": false,
        "NSCameraUsageDescription": false,
        "NSMicrophoneUsageDescription": false,
        "NSAppleEventsUsageDescription": "Atlas Installer needs to run administrative commands to install the Atlas binary to /usr/local/bin/",
        "NSSystemAdministrationUsageDescription": "Atlas Installer needs administrative access to install the Atlas binary to /usr/local/bin/",
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": false
        }
      }
    },
    "buildDependenciesFromSource": false,
    "compression": "normal",
    "removePackageScripts": true,
    "removePackageKeywords": true,
    "nodeGypRebuild": false,
    "npmRebuild": false,
    "win": {
      "target": "portable",
      "icon": "icons/icon.ico"
    },
    "linux": {
      "target": "AppImage",
      "category": "Development",
      "icon": "icons"
    },
    "electronDownload": {
      "cache": "./electron-cache"
    }
  }
}
