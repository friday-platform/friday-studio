{
  "name": "@atlas/memory-manager",
  "exports": "./main.ts",
  "tasks": {
    "start": "deno run --allow-read --allow-write --allow-env --allow-net --allow-ffi --allow-sys --unstable-kv main.ts",
    "stats": "deno run --allow-read --allow-write --allow-env --allow-net --allow-ffi --allow-sys --unstable-kv main.ts --stats",
    "export": "deno run --allow-read --allow-write --allow-env --allow-net --allow-ffi --allow-sys --unstable-kv main.ts --export",
    "validate": "deno run --allow-read --allow-write --allow-env --allow-net --allow-ffi --allow-sys --unstable-kv main.ts --validate",
    "check": "deno check main.ts src/tui.ts utils/memory-loader.ts types/memory-types.ts"
  },
  "imports": {
    "@std/cli": "jsr:@std/cli@^1.0.20",
    "@std/fs": "jsr:@std/fs@^1.0.19",
    "@std/path": "jsr:@std/path@^1.1.1",
    "@atlas/memory": "./../../packages/memory/mod.ts",
    "@std/crypto": "jsr:@std/crypto@^1.0.5"
  }
}
