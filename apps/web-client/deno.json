    "@tauri-apps/plugin-shell": "npm:@tauri-apps/plugin-shell@^2.3.1",
    "cookie": "npm:cookie@^1.0.2",
    "eslint": "npm:eslint@^9.18.0",
    "eslint-config-prettier": "npm:eslint-config-prettier@^10.0.1",
    "eslint-plugin-svelte": "npm:eslint-plugin-svelte@^3.0.0",
    "globals": "npm:globals@^16.0.0",
    "nanoid": "npm:nanoid@^5.1.5",
