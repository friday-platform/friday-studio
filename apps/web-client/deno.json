{
  "name": "@atlas/web-client",
  "version": "0.0.1",
  "exports": "./mod.ts",
  "tasks": {
    "svelte-dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "format": "prettier --write .",
    "lint": "prettier --check . && eslint ."
  },
  "imports": {
    "@deno/vite-plugin": "npm:@deno/vite-plugin@^1.0.5",
    "@lezer/markdown": "npm:@lezer/markdown@^1.3.2",
    "@lezer/common": "npm:@lezer/common@^1.2.3",
    "@melt-ui/svelte": "npm:@melt-ui/svelte@^0.86.6",
    "@tanstack/svelte-table": "npm:@tanstack/svelte-table@^8.21.3",
    "knip": "npm:knip@^5.62.0",
    "nanoid": "npm:nanoid@^5.1.5",
    "streaming-markdown": "npm:streaming-markdown@^0.2.15",
    "svelte-adapter-deno": "npm:svelte-adapter-deno@^0.9.1",
    "svelte-eslint-parser": "npm:svelte-eslint-parser@^1.3.1",
    "svelte-preprocess": "npm:svelte-preprocess@^6.0.3",
    "vitest": "npm:vitest@^3.2.4",
    "@eslint/compat": "npm:@eslint/compat@^1.2.5",
    "@eslint/js": "npm:@eslint/js@^9.18.0",
    "@sveltejs/adapter-auto": "npm:@sveltejs/adapter-auto@^6.0.0",
    "@sveltejs/kit": "npm:@sveltejs/kit@^2.22.0",
    "@sveltejs/vite-plugin-svelte": "npm:@sveltejs/vite-plugin-svelte@^6.0.0",
    "eslint": "npm:eslint@^9.18.0",
    "eslint-config-prettier": "npm:eslint-config-prettier@^10.0.1",
    "eslint-plugin-svelte": "npm:eslint-plugin-svelte@^3.0.0",
    "globals": "npm:globals@^16.0.0",
    "prettier": "npm:prettier@^3.4.2",
    "prettier-plugin-svelte": "npm:prettier-plugin-svelte@^3.3.3",
    "svelte": "npm:svelte@^5.0.0",
    "svelte-check": "npm:svelte-check@^4.0.0",
    "typescript": "npm:typescript@^5.0.0",
    "typescript-eslint": "npm:typescript-eslint@^8.20.0",
    "vite": "npm:vite@^7.0.4"
  }
}
