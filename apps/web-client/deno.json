    "@lezer/markdown": "npm:@lezer/markdown@^1.3.2",
    "@melt-ui/svelte": "npm:@melt-ui/svelte@^0.86.6",
    "@rollup/rollup-darwin-arm64": "npm:@rollup/rollup-darwin-arm64@^4.49.0",
    "@sveltejs/adapter-auto": "npm:@sveltejs/adapter-auto@^6.0.0",
    "@sveltejs/adapter-static": "npm:@sveltejs/adapter-static@^3.0.6",
    "@sveltejs/kit": "npm:@sveltejs/kit@^2.22.0",
    "@sveltejs/vite-plugin-svelte": "npm:@sveltejs/vite-plugin-svelte@^6.0.0",
