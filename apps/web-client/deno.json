{
  "name": "@atlas/web-client",
  "version": "0.0.1",
  "exports": "./mod.ts",
  "tasks": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
