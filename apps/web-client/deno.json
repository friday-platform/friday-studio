{
  "name": "@atlas/web-client",
  "version": "1.0.0-beta",
  "exports": "./mod.ts",
  "exclude": [
    ".svelte-kit/**",
    "build/**",
    "dist/**",
    "node_modules/**",
    "src/lib/**/*.svelte.ts",
    "src/routes/**/*.svelte",
    "src/routes/**/+server.ts",
    "src/routes/**/+page.ts",
    "src/routes/**/+layout.ts",
    "src/routes/**/+page.server.ts",
    "src/routes/**/+layout.server.ts",
    "src/hooks.server.ts"
  ],
  "tasks": {
    "dev": "vite dev",
    "build": "deno run --allow-read --allow-write --allow-env scripts/generate-build-info.ts && vite build",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "fmt": "npx prettier --write .",
    "fmt:check": "npx prettier --check .",
    "lint": "npx prettier --check . && npx eslint .",
    "eslint": "npx eslint .",
    "tauri": "tauri"
  }
}
