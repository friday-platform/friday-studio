    "svelte-eslint-parser": "npm:svelte-eslint-parser@^1.3.1",
    "svelte-preprocess": "npm:svelte-preprocess@^6.0.3",
    "typescript": "npm:typescript@^5.0.0",
    "typescript-eslint": "npm:typescript-eslint@^8.20.0",
    "vite": "npm:vite@^7.0.4",
