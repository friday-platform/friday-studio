{
  "name": "@atlas/web-client",
  "version": "1.0.0-beta",
  "type": "module",
  "main": "./mod.ts",
  "exports": {
    ".": "./mod.ts"
  },
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "build:full": "node scripts/generate-build-info.js && vite build",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "sync": "svelte-kit sync",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "prettier --check . && eslint .",
    "tauri": "tauri",
    "tauri:build": "tauri build",
    "vitest": "vitest run",
    "generate-build-info": "deno run --allow-read --allow-write --allow-env scripts/generate-build-info.ts"
  },
  "dependencies": {
    "@ai-sdk/svelte": "^3.0.139",
    "@atlas/analytics": "workspace:*",
    "@atlas/core": "workspace:*",
    "@atlas/oapi-client": "workspace:*",
    "@atlas/system": "workspace:*",
    "@lezer/common": "^1.5.1",
    "@lezer/markdown": "^1.6.3",
    "@melt-ui/svelte": "^0.86.6",
    "@sentry/sveltekit": "^10.40.0",
    "@std/yaml": "npm:@jsr/std__yaml@^1.0.10",
    "@sveltejs/kit": "^2.53.2",
    "@tanstack/query-core": "^5.90.20",
    "@tanstack/svelte-query": "^6.0.18",
    "@tanstack/svelte-table": "9.0.0-alpha.10",
    "@tauri-apps/api": "2.10.1",
    "@tauri-apps/plugin-fs": "~2.4.5",
    "@tauri-apps/plugin-opener": "^2.5.3",
    "@types/papaparse": "^5.5.2",
    "ai": "^5.0.138",
    "papaparse": "^5.5.3",
    "svelte": "^5.53.5",
    "svelte-exmarkdown": "^5.0.2",
    "vite": "^7.3.1",
    "vitest": "^4.0.18",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.2",
    "@eslint/js": "^10.0.1",
    "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/vite-plugin-svelte": "~6.2.4",
    "@tauri-apps/cli": "^2.10.0",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.15.0",
    "globals": "^17.3.0",
    "prettier": "^3.8.1",
    "prettier-plugin-svelte": "^3.4.1",
    "svelte-check": "^4.4.3",
    "svelte-eslint-parser": "^1.5.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  }
}
