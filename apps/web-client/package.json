{
  "name": "@atlas/web-client",
  "version": "0.0.1",
  "type": "module",
  "main": "./mod.ts",
  "exports": { ".": "./mod.ts" },
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "build:full": "node scripts/generate-build-info.js && vite build",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "format": "prettier --write .",
    "lint": "prettier --check . && eslint .",
    "tauri": "tauri",
    "tauri:build": "tauri build",
    "generate-build-info": "deno run --allow-read --allow-write --allow-env scripts/generate-build-info.ts"
  },
  "dependencies": {
    "@atlas/core": "workspace:*",
    "@atlas/oapi-client": "workspace:*",
    "@lezer/common": "^1.2.3",
    "@lezer/markdown": "^1.3.2",
    "@sveltejs/kit": "^2.22.0",
    "@tauri-apps/api": "^2.8.0",
    "@tauri-apps/plugin-dialog": "^2.4.0",
    "@tauri-apps/plugin-notification": "^2.0.0",
    "@tauri-apps/plugin-opener": "^2.5.0",
    "ai": "^5.0.17",
    "cookie": "^1.0.2",
    "eventsource-client": "^1.1.4",
    "svelte": "^5.0.0",
    "zod": "^3.25.74"
  },
  "devDependencies": {
    "@eslint/compat": "^1.2.5",
    "@eslint/js": "^9.18.0",
    "@ianvs/prettier-plugin-sort-imports": "^4.4.1",
    "@std/assert": "npm:@jsr/std__assert@^1.0.14",
    "@sveltejs/adapter-static": "^3.0.6",
    "@sveltejs/vite-plugin-svelte": "^6.0.0",
    "@tauri-apps/cli": "^2.8.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-svelte": "^3.0.0",
    "globals": "^16.0.0",
    "prettier": "^3.4.2",
    "prettier-plugin-svelte": "^3.3.3",
    "svelte-check": "^4.0.0",
    "svelte-eslint-parser": "^1.3.1",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.20.0",
    "vite": "^7.0.4",
    "vite-tsconfig-paths": "^5.1.2"
  }
}
