{
  "name": "@atlas/web-client",
  "version": "0.0.1",
  "type": "module",
  "main": "./mod.ts",
  "exports": { ".": "./mod.ts" },
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "build:full": "node scripts/generate-build-info.js && vite build",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "sync": "svelte-kit sync",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "format": "prettier --write .",
    "lint": "prettier --check . && eslint .",
    "tauri": "tauri",
    "tauri:build": "tauri build",
    "generate-build-info": "deno run --allow-read --allow-write --allow-env scripts/generate-build-info.ts"
  },
  "dependencies": {
    "@atlas/core": "workspace:*",
    "@atlas/oapi-client": "workspace:*",
    "@ai-sdk/svelte": "^3.0.112",
    "@sentry/sveltekit": "^10.30.0",
    "@melt-ui/svelte": "^0.86.6",
    "@lezer/common": "^1.4.0",
    "@lezer/markdown": "^1.6.1",
    "@std/yaml": "npm:@jsr/std__yaml@^1.0.10",
    "@sveltejs/kit": "^2.49.2",
    "@tanstack/svelte-table": "9.0.0-alpha.10",
    "@tauri-apps/api": "2.9.1",
    "@tauri-apps/plugin-fs": "~2.4.4",
    "@tauri-apps/plugin-notification": "^2.3.3",
    "@tauri-apps/plugin-opener": "^2.5.2",
    "ai": "^5.0.112",
    "eventsource-client": "^1.2.0",
    "svelte": "^5.45.10",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.0",
    "@eslint/js": "^9.39.1",
    "@ianvs/prettier-plugin-sort-imports": "^4.7.0",
    "@std/assert": "npm:@jsr/std__assert@^1.0.14",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/vite-plugin-svelte": "^6.2.1",
    "@tauri-apps/cli": "^2.9.6",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.13.1",
    "globals": "^16.5.0",
    "prettier": "^3.7.4",
    "prettier-plugin-svelte": "^3.4.0",
    "svelte-check": "^4.3.4",
    "svelte-eslint-parser": "^1.4.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.49.0",
    "vite": "^7.2.7"
  }
}
