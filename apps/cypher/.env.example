# Server Configuration
PORT=8085
METRICS_PORT=9090
SERVICE_NAME=cypher
LOG_LEVEL=debug

# Database Configuration
# Use search_path=cypher to default to the cypher schema
POSTGRES_CONNECTION=postgresql://postgres:postgres@localhost:54322/postgres?sslmode=disable&search_path=cypher

# Cache Configuration
# Maximum number of AEAD primitives to cache in memory
CACHE_SIZE=10000

# KMS Configuration
# Options: googlekms, fake
# Use 'fake' for local development (WARNING: no encryption)
# Use 'googlekms' for production with Google Cloud KMS
KMS_PROVIDER=fake

# Google Cloud KMS (required when KMS_PROVIDER=googlekms)
# Format: gcp-kms://projects/PROJECT_ID/locations/LOCATION/keyRings/KEY_RING/cryptoKeys/KEY
# GOOGLE_KMS_KEY_URI=gcp-kms://projects/tempest-production/locations/global/keyRings/atlas-cypher/cryptoKeys/master-key

# For local development with Google Cloud KMS, set:
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json
# In GKE with Workload Identity, credentials are provided automatically.

# TLS Configuration (optional, for production)
# TLS_CERTIFICATE_PATH=/cert-volume/tls.crt
# TLS_KEY_PATH=/cert-volume/tls.key
# TLS_CA_PATH=/cert-volume/ca.crt

# Profiler Configuration (optional)
# PROFILER_ENABLED=false
