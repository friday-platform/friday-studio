# Server Configuration
PORT=8083

# Database
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# JWT Keys
JWT_PRIVATE_KEY_PATH=../../.local-dev/secrets/jwt-private.key
JWT_PUBLIC_KEY_PATH=../../.local-dev/secrets/jwt-public.key

# OAuth - Google
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8083/oauth/google/callback

# SendGrid
SENDGRID_API_KEY=your-sendgrid-api-key
SENDGRID_FROM_EMAIL=noreply@atlas.tempestdx.dev
SENDGRID_TEMPLATE_ID=your-sendgrid-template-id

# URLs
APP_URL=http://localhost:5173
COOKIE_DOMAIN=localhost

# Atlas Operator Webhook (optional for local dev)
ATLAS_OPERATOR_WEBHOOK_URL=
ATLAS_OPERATOR_WEBHOOK_KEY=
