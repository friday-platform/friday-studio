# Signal Gateway Configuration

# Service
SERVICE_NAME=signal-gateway
PORT=8080
METRICS_PORT=9090
LOG_LEVEL=info

# Atlas routing
# Production: Use template with %s for user_id substitution
ATLAS_URL_TEMPLATE=https://atlas-%s.atlas.svc.cluster.local
# Local development: Use localhost without substitution
# ATLAS_URL_TEMPLATE=http://localhost:8080

# Timeouts
ATLAS_TIMEOUT_SECONDS=10

# TLS (production only - handled by pkg/server)
TLS_CERTIFICATE_PATH=/cert-volume/tls.crt
TLS_KEY_PATH=/cert-volume/tls.key
TLS_CA_PATH=/cert-volume/ca.crt

# OTEL (optional)
OTEL_EXPORTER_OTLP_ENDPOINT=https://atlas-otel-collector.atlas-operator.svc.cluster.local:4318
OTEL_EXPORTER_OTLP_CERTIFICATE=/cert-volume/ca.crt

# Profiler (optional - Google Cloud Profiler)
PROFILER_ENABLED=false
PROFILER_PROJECT_ID=tempest-production
