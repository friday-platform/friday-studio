# Server configuration
PORT=8084
LOG_LEVEL=debug
SERVICE_NAME=gist

# GCS configuration (required)
GCS_BUCKET=atlas-sandbox-gist

# Share URL base (required) - the public URL where shared content is accessible
SHARE_BASE_URL=https://share.hellofriday.dev

# Local development only - path to service account JSON
# Leave empty in production (uses Workload Identity)
SERVICE_ACCOUNT_KEY_FILE=

# Upload limits
MAX_UPLOAD_SIZE=10485760

# CORS
CORS_ALLOWED_ORIGINS=*

# TLS (optional)
# TLS_CERTIFICATE_PATH=
# TLS_KEY_PATH=
