{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the installer window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:default",
    "core:window:allow-close",
    "shell:default",
    "shell:allow-execute",
    "shell:allow-open",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        { "name": "exec-sh", "cmd": "sh", "args": ["-c", { "validator": "^.+$" }] },
        {
          "name": "exec-powershell",
          "cmd": "powershell",
          "args": ["-Command", { "validator": "^.+$" }]
        },
        { "name": "exec-osascript", "cmd": "osascript", "args": ["-e", { "validator": "^.+$" }] }
      ]
    },
    "dialog:default"
  ]
}
