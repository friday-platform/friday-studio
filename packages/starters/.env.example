# Atlas Environment Variables
# Rename this file to .env and fill in your API keys

# Anthropic Claude API Key
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=xxxxxx

# OpenAI API Key - Required to use OpenAI models
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=xxxxxx

# Google AI API Key - Required to use Gemini models
# Get from: https://aistudio.google.com/app/apikey
GOOGLE_GENERATIVE_AI_API_KEY=xxxxxx

# Optional: GitHub token for repository operations
# GITHUB_TOKEN=your-github-token-here

# Optional: Workspace-specific settings
# WORKSPACE_LOG_LEVEL=info
# WORKSPACE_TIMEOUT=300000

# Optional: Custom API endpoints
# ATLAS_API_URL=http://localhost:8080
# CUSTOM_LLM_ENDPOINT=https://your-llm-endpoint.com
