{
  "workspace": {
    "name": "research-briefing",
    "purpose": "Research a topic from multiple sources and produce a consolidated briefing"
  },
  "signals": [
    {
      "id": "research-requested",
      "name": "Research Request",
      "title": "Start research briefing",
      "signalType": "http",
      "description": "Triggered when a user requests a research briefing on a topic",
      "signalConfig": { "provider": "http", "config": { "path": "/webhook/research-requested" } },
      "payloadSchema": {
        "type": "object",
        "properties": {
          "topic": { "type": "string", "description": "Research topic to investigate" },
          "artifact_ref": {
            "type": "string",
            "description": "Optional artifact reference for supplementary data"
          }
        },
        "required": ["topic"]
      }
    }
  ],
  "agents": [
    {
      "id": "research",
      "name": "Web Researcher",
      "description": "Searches the web for current information on the given topic",
      "capabilities": ["research"]
    },
    {
      "id": "data-analyst",
      "name": "Data Analyst",
      "description": "Analyzes any structured data related to the research topic",
      "capabilities": ["data-analyst"]
    },
    {
      "id": "get-summary",
      "name": "Briefing Summarizer",
      "description": "Consolidates web research and data analysis into a single briefing document",
      "capabilities": ["get-summary"]
    }
  ],
  "jobs": [
    {
      "id": "build-briefing",
      "name": "Build Research Briefing",
      "title": "Research Briefing",
      "triggerSignalId": "research-requested",
      "steps": [
        {
          "id": "search-web",
          "agentId": "research",
          "description": "Search the web for recent information and context on the topic",
          "depends_on": [],
          "executionType": "bundled"
        },
        {
          "id": "analyze-data",
          "agentId": "data-analyst",
          "description": "Analyze any structured data related to the research topic",
          "depends_on": [],
          "executionType": "bundled"
        },
        {
          "id": "summarize-findings",
          "agentId": "get-summary",
          "description": "Consolidate findings from web research and data analysis into a briefing",
          "depends_on": ["search-web", "analyze-data"],
          "executionType": "bundled"
        }
      ],
      "documentContracts": [
        {
          "producerStepId": "search-web",
          "documentId": "web-research-output",
          "documentType": "research",
          "schema": {
            "type": "object",
            "properties": {
              "response": { "type": "string", "description": "Research summary narrative" }
            },
            "required": ["response"]
          }
        },
        {
          "producerStepId": "analyze-data",
          "documentId": "data-analysis-output",
          "documentType": "summary",
          "schema": {
            "type": "object",
            "properties": {
              "summary": { "type": "string", "description": "Analysis narrative" },
              "queries": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "sql": { "type": "string" },
                    "success": { "type": "boolean" },
                    "rowCount": { "type": "number" },
                    "error": { "type": "string" },
                    "durationMs": { "type": "number" },
                    "tool": { "type": "string", "enum": ["execute_sql", "save_results"] }
                  },
                  "required": ["sql", "success", "rowCount", "error", "durationMs", "tool"]
                }
              }
            },
            "required": ["summary", "queries"]
          }
        }
      ],
      "prepareMappings": [
        {
          "consumerStepId": "summarize-findings",
          "documentId": "web-research-output",
          "documentType": "research",
          "sources": [{ "from": "response", "to": "web_findings" }],
          "constants": []
        },
        {
          "consumerStepId": "summarize-findings",
          "documentId": "data-analysis-output",
          "documentType": "summary",
          "sources": [{ "from": "summary", "to": "data_findings" }],
          "constants": []
        }
      ]
    }
  ]
}
