{
  "workspace": {
    "name": "competitor-briefing",
    "purpose": "Weekly competitor news summary delivered via email"
  },
  "signals": [
    {
      "id": "weekly-monday",
      "name": "Weekly Monday Trigger",
      "title": "Weekly competitor scan",
      "signalType": "schedule",
      "description": "Fires every Monday morning to trigger competitor research",
      "signalConfig": {
        "provider": "schedule",
        "config": { "schedule": "0 9 * * 1", "timezone": "America/Denver" }
      }
    }
  ],
  "agents": [
    {
      "id": "research",
      "name": "Competitor Researcher",
      "description": "Searches the web for recent news about a list of competitors",
      "needs": ["web-search"]
    },
    {
      "id": "get-summary",
      "name": "Briefing Writer",
      "description": "Consolidates competitor news into a structured briefing with source links",
      "needs": ["summarization"]
    },
    {
      "id": "email",
      "name": "Briefing Sender",
      "description": "Sends the competitor briefing email to the user",
      "needs": ["email", "sendgrid"]
    }
  ],
  "jobs": [
    {
      "id": "weekly-competitor-scan",
      "name": "Weekly Competitor Scan",
      "title": "Competitor Briefing",
      "triggerSignalId": "weekly-monday",
      "steps": [
        {
          "id": "search-competitors",
          "agentId": "research",
          "description": "Search for recent news about each competitor in the watch list",
          "depends_on": [],
          "executionType": "bundled"
        },
        {
          "id": "write-briefing",
          "agentId": "get-summary",
          "description": "Consolidate findings into a structured briefing with sections per competitor",
          "depends_on": ["search-competitors"],
          "executionType": "bundled"
        },
        {
          "id": "send-briefing",
          "agentId": "email",
          "description": "Email the briefing to the workspace owner",
          "depends_on": ["write-briefing"],
          "executionType": "bundled"
        }
      ],
      "documentContracts": [
        {
          "producerStepId": "search-competitors",
          "documentId": "competitor-news",
          "documentType": "research",
          "schema": {
            "type": "object",
            "properties": {
              "response": { "type": "string", "description": "Research findings with source links" }
            },
            "required": ["response"]
          }
        },
        {
          "producerStepId": "write-briefing",
          "documentId": "briefing-output",
          "documentType": "summary",
          "schema": {
            "type": "object",
            "properties": {
              "briefing": {
                "type": "string",
                "description": "Formatted competitor briefing with sections per competitor"
              },
              "competitor_count": {
                "type": "number",
                "description": "Number of competitors covered"
              }
            },
            "required": ["briefing", "competitor_count"]
          }
        },
        {
          "producerStepId": "send-briefing",
          "documentId": "email-confirmation",
          "documentType": "email-result",
          "schema": {
            "type": "object",
            "properties": {
              "response": { "type": "string", "description": "Email send confirmation" },
              "message_id": { "type": "string", "description": "SendGrid message ID" }
            },
            "required": ["response"]
          }
        }
      ],
      "prepareMappings": [
        {
          "consumerStepId": "write-briefing",
          "documentId": "competitor-news",
          "documentType": "research",
          "sources": [{ "from": "response", "to": "research_findings" }],
          "constants": [{ "key": "format", "value": "competitor_briefing" }]
        },
        {
          "consumerStepId": "send-briefing",
          "documentId": "competitor-news",
          "documentType": "research",
          "sources": [{ "from": "response", "to": "body" }],
          "constants": [
            { "key": "subject", "value": "Weekly Competitor Briefing" },
            { "key": "to", "value": "user@example.com" }
          ]
        }
      ]
    }
  ]
}
