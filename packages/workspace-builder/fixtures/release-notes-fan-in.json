{
  "workspace": {
    "name": "release-notes-generator",
    "purpose": "Generate release notes from PRs and commits, then save to Notion"
  },
  "signals": [
    {
      "id": "weekly-release",
      "name": "Weekly Release Trigger",
      "title": "Generate release notes",
      "signalType": "schedule",
      "description": "Fires every Friday to generate weekly release notes",
      "signalConfig": {
        "provider": "schedule",
        "config": { "schedule": "0 9 * * 5", "timezone": "America/Denver" }
      }
    }
  ],
  "agents": [
    {
      "id": "research",
      "name": "PR Fetcher",
      "description": "Fetches merged PRs from GitHub for the current week",
      "capabilities": ["github"]
    },
    {
      "id": "data-analyst",
      "name": "Commit Analyzer",
      "description": "Analyzes commit history and code changes for the week",
      "capabilities": ["data-analyst"]
    },
    {
      "id": "get-summary",
      "name": "Release Notes Writer",
      "description": "Consolidates PR and commit data into formatted release notes",
      "capabilities": ["get-summary"]
    },
    {
      "id": "slack",
      "name": "Release Announcer",
      "description": "Posts release notes to the #releases Slack channel",
      "capabilities": ["slack"]
    }
  ],
  "jobs": [
    {
      "id": "generate-release-notes",
      "name": "Generate Weekly Release Notes",
      "title": "Release Notes",
      "triggerSignalId": "weekly-release",
      "steps": [
        {
          "id": "fetch-prs",
          "agentId": "research",
          "executionRef": "research",
          "description": "Fetch all merged PRs from the last week",
          "depends_on": [],
          "executionType": "bundled"
        },
        {
          "id": "analyze-commits",
          "agentId": "data-analyst",
          "executionRef": "data-analyst",
          "description": "Analyze commit history and categorize changes",
          "depends_on": [],
          "executionType": "bundled"
        },
        {
          "id": "write-notes",
          "agentId": "get-summary",
          "executionRef": "get-summary",
          "description": "Consolidate PR and commit data into release notes grouped by features, improvements, and fixes",
          "depends_on": ["fetch-prs", "analyze-commits"],
          "executionType": "bundled"
        },
        {
          "id": "announce-release",
          "agentId": "slack",
          "executionRef": "slack",
          "description": "Post release notes to the #releases channel",
          "depends_on": ["write-notes"],
          "executionType": "bundled"
        }
      ],
      "documentContracts": [
        {
          "producerStepId": "fetch-prs",
          "documentId": "pr-data",
          "documentType": "research",
          "schema": {
            "type": "object",
            "properties": {
              "response": {
                "type": "string",
                "description": "PR summaries with titles and descriptions"
              }
            },
            "required": ["response"]
          }
        },
        {
          "producerStepId": "analyze-commits",
          "documentId": "commit-analysis",
          "documentType": "summary",
          "schema": {
            "type": "object",
            "properties": {
              "summary": { "type": "string", "description": "Commit analysis narrative" },
              "queries": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "sql": { "type": "string" },
                    "success": { "type": "boolean" },
                    "rowCount": { "type": "number" },
                    "error": { "type": "string" },
                    "durationMs": { "type": "number" },
                    "tool": { "type": "string", "enum": ["execute_sql", "save_results"] }
                  },
                  "required": ["sql", "success", "rowCount", "error", "durationMs", "tool"]
                }
              }
            },
            "required": ["summary", "queries"]
          }
        },
        {
          "producerStepId": "announce-release",
          "documentId": "slack-announcement",
          "documentType": "slack-result",
          "schema": {
            "type": "object",
            "properties": {
              "response": { "type": "string", "description": "Slack post confirmation" }
            },
            "required": ["response"]
          }
        }
      ],
      "prepareMappings": [
        {
          "consumerStepId": "write-notes",
          "documentId": "pr-data",
          "documentType": "research",
          "sources": [{ "from": "response", "to": "pr_summaries" }],
          "constants": []
        },
        {
          "consumerStepId": "write-notes",
          "documentId": "commit-analysis",
          "documentType": "summary",
          "sources": [{ "from": "summary", "to": "commit_analysis" }],
          "constants": [{ "key": "format", "value": "release_notes" }]
        },
        {
          "consumerStepId": "announce-release",
          "documentId": "pr-data",
          "documentType": "research",
          "sources": [{ "from": "response", "to": "message" }],
          "constants": [{ "key": "channel", "value": "#releases" }]
        }
      ]
    }
  ]
}
