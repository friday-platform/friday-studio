{
  "workspace": {
    "name": "order-receipt-generator",
    "purpose": "Process orders and generate receipts with computed totals and tax calculations"
  },
  "signals": [
    {
      "id": "order-placed",
      "name": "Order Placed",
      "title": "Process new order",
      "signalType": "http",
      "description": "Triggered when a new order is placed via the API",
      "signalConfig": { "provider": "http", "config": { "path": "/webhook/order" } },
      "payloadSchema": {
        "type": "object",
        "properties": {
          "order_id": { "type": "string", "description": "Unique order identifier" }
        },
        "required": ["order_id"]
      }
    }
  ],
  "agents": [
    {
      "id": "rate-fetcher",
      "name": "Rate Fetcher",
      "description": "Fetches current tax rates for the customer's region",
      "needs": ["tax-rates"]
    },
    {
      "id": "order-processor",
      "name": "Order Processor",
      "description": "Processes and validates order data, producing structured line items",
      "needs": ["order-processing"]
    },
    {
      "id": "receipt-sender",
      "name": "Receipt Sender",
      "description": "Sends a receipt email with computed totals to the customer",
      "needs": ["email"]
    }
  ],
  "jobs": [
    {
      "id": "process-and-receipt",
      "name": "Process Order and Send Receipt",
      "title": "Order Receipt",
      "triggerSignalId": "order-placed",
      "steps": [
        {
          "id": "fetch-rates",
          "agentId": "rate-fetcher",
          "description": "Fetch current tax rates for the order's region",
          "depends_on": [],
          "executionType": "llm",
          "tools": ["webfetch"]
        },
        {
          "id": "process-order",
          "agentId": "order-processor",
          "description": "Extract and validate order details from the incoming data",
          "depends_on": ["fetch-rates"],
          "executionType": "llm"
        },
        {
          "id": "send-receipt",
          "agentId": "receipt-sender",
          "description": "Send receipt email with subtotal, tax, and total to the customer",
          "depends_on": ["process-order"],
          "executionType": "llm",
          "tools": ["sendgrid"]
        }
      ],
      "documentContracts": [
        {
          "producerStepId": "fetch-rates",
          "documentId": "rate-config",
          "documentType": "config",
          "schema": {
            "type": "object",
            "properties": {
              "tax_rate": { "type": "number", "description": "Tax rate as a decimal (e.g. 0.075)" },
              "region": { "type": "string", "description": "Tax region code" }
            },
            "required": ["tax_rate", "region"]
          }
        },
        {
          "producerStepId": "process-order",
          "documentId": "order-output",
          "documentType": "order",
          "schema": {
            "type": "object",
            "properties": {
              "customer_email": { "type": "string", "description": "Customer email address" },
              "customer_name": { "type": "string", "description": "Full customer name" },
              "line_items": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "name": { "type": "string" },
                    "amount": { "type": "number" },
                    "quantity": { "type": "number" }
                  },
                  "required": ["name", "amount", "quantity"]
                }
              }
            },
            "required": ["customer_email", "customer_name", "line_items"]
          }
        },
        {
          "producerStepId": "send-receipt",
          "documentId": "receipt-confirmation",
          "documentType": "email-result",
          "schema": {
            "type": "object",
            "properties": { "sent": { "type": "boolean" }, "message_id": { "type": "string" } },
            "required": ["sent"]
          }
        }
      ],
      "prepareMappings": [
        {
          "consumerStepId": "send-receipt",
          "documentId": "order-output",
          "documentType": "order",
          "sources": [
            { "from": "customer_email", "to": "recipient" },
            { "from": "customer_name", "to": "customer_name" },
            {
              "from": "line_items",
              "to": "subtotal",
              "transform": "value.reduce((sum, i) => sum + i.amount * i.quantity, 0)",
              "description": "Compute order subtotal from line item amounts times quantities"
            },
            {
              "from": "line_items",
              "to": "item_count",
              "transform": "value.length",
              "description": "Count number of line items"
            },
            {
              "from": "line_items",
              "to": "total_with_tax",
              "transform": "value.reduce((sum, i) => sum + i.amount * i.quantity, 0) * (1 + docs['rate-config'].tax_rate)",
              "description": "Compute total including tax using rate from rate-config document"
            }
          ],
          "constants": [{ "key": "currency", "value": "USD" }]
        }
      ]
    }
  ]
}
