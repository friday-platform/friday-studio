{
  "workspace": {
    "name": "survey-response-analysis",
    "purpose": "Analyze survey responses, group by theme, and summarize top insights"
  },
  "signals": [
    {
      "id": "survey-data-ready",
      "name": "Survey Data Available",
      "title": "Analyze survey responses",
      "signalType": "http",
      "description": "Triggered when new survey response data is uploaded",
      "signalConfig": { "provider": "http", "config": { "path": "/webhook/survey-data-ready" } },
      "payloadSchema": {
        "type": "object",
        "properties": {
          "artifact_ref": {
            "type": "string",
            "description": "Artifact reference to the survey data"
          },
          "survey_name": { "type": "string", "description": "Name of the survey for context" }
        },
        "required": ["artifact_ref", "survey_name"]
      }
    }
  ],
  "agents": [
    {
      "id": "data-analyst",
      "name": "Survey Analyzer",
      "description": "Analyzes survey responses using SQL to identify themes and patterns",
      "needs": ["data-analysis", "sql"]
    },
    {
      "id": "get-summary",
      "name": "Insights Writer",
      "description": "Writes up the top insights and patterns from the analysis",
      "needs": ["summarization"]
    },
    {
      "id": "email",
      "name": "Report Sender",
      "description": "Sends the analysis report via email",
      "needs": ["email", "sendgrid"]
    }
  ],
  "jobs": [
    {
      "id": "analyze-survey",
      "name": "Analyze Survey Responses",
      "title": "Survey Analysis",
      "triggerSignalId": "survey-data-ready",
      "steps": [
        {
          "id": "run-analysis",
          "agentId": "data-analyst",
          "description": "Run SQL queries to group responses by theme and calculate frequencies",
          "depends_on": [],
          "executionType": "bundled"
        },
        {
          "id": "write-insights",
          "agentId": "get-summary",
          "description": "Write a narrative summary of the top themes and actionable insights",
          "depends_on": ["run-analysis"],
          "executionType": "bundled"
        },
        {
          "id": "send-report",
          "agentId": "email",
          "description": "Email the insights report to stakeholders",
          "depends_on": ["write-insights"],
          "executionType": "bundled"
        }
      ],
      "documentContracts": [
        {
          "producerStepId": "run-analysis",
          "documentId": "survey-analysis-result",
          "documentType": "summary",
          "schema": {
            "type": "object",
            "properties": {
              "summary": {
                "type": "string",
                "description": "Analysis narrative with theme groupings"
              },
              "queries": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "sql": { "type": "string" },
                    "success": { "type": "boolean" },
                    "rowCount": { "type": "number" },
                    "error": { "type": "string" },
                    "durationMs": { "type": "number" },
                    "tool": { "type": "string", "enum": ["execute_sql", "save_results"] }
                  },
                  "required": ["sql", "success", "rowCount", "error", "durationMs", "tool"]
                }
              }
            },
            "required": ["summary", "queries"]
          }
        },
        {
          "producerStepId": "send-report",
          "documentId": "email-confirmation",
          "documentType": "email-result",
          "schema": {
            "type": "object",
            "properties": {
              "response": { "type": "string", "description": "Email send confirmation" }
            },
            "required": ["response"]
          }
        }
      ],
      "prepareMappings": [
        {
          "consumerStepId": "write-insights",
          "documentId": "survey-analysis-result",
          "documentType": "summary",
          "sources": [
            { "from": "summary", "to": "analysis_text" },
            { "from": "queries", "to": "query_details" }
          ],
          "constants": [{ "key": "focus", "value": "actionable_insights" }]
        },
        {
          "consumerStepId": "send-report",
          "documentId": "survey-analysis-result",
          "documentType": "summary",
          "sources": [{ "from": "summary", "to": "body" }],
          "constants": [
            { "key": "subject", "value": "Survey Analysis Report" },
            { "key": "to", "value": "stakeholders@example.com" }
          ]
        }
      ]
    }
  ]
}
