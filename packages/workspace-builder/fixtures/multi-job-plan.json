{
  "workspace": {
    "name": "multi-workflow-hub",
    "purpose": "Two independent workflows: daily data sync and webhook processing"
  },
  "signals": [
    {
      "id": "daily-schedule",
      "name": "Daily Schedule",
      "title": "Run daily data sync",
      "signalType": "schedule",
      "description": "Fires daily to fetch and analyze external data",
      "signalConfig": {
        "provider": "schedule",
        "config": { "schedule": "0 9 * * *", "timezone": "America/Denver" }
      }
    },
    {
      "id": "webhook-received",
      "name": "Webhook Received",
      "title": "Process incoming webhook",
      "signalType": "http",
      "description": "Triggered when an external webhook payload arrives",
      "signalConfig": { "provider": "http", "config": { "path": "/webhook/webhook-received" } }
    }
  ],
  "agents": [
    {
      "id": "data-fetcher",
      "name": "Data Fetcher",
      "description": "Fetches data from external APIs",
      "needs": ["http"]
    },
    {
      "id": "data-analyst",
      "name": "Data Analyst",
      "description": "Analyzes fetched data and produces summaries",
      "needs": ["data-analysis"]
    },
    {
      "id": "notifier",
      "name": "Notifier",
      "description": "Sends notifications via Slack or email",
      "needs": ["slack", "email"]
    }
  ],
  "jobs": [
    {
      "id": "daily-sync",
      "name": "Daily Data Sync",
      "title": "Fetch, Analyze, Notify",
      "triggerSignalId": "daily-schedule",
      "steps": [
        {
          "id": "fetch-data",
          "agentId": "data-fetcher",
          "description": "Fetch latest data from external API",
          "depends_on": [],
          "executionType": "llm",
          "tools": ["webfetch"]
        },
        {
          "id": "analyze-data",
          "agentId": "data-analyst",
          "description": "Analyze fetched data for trends",
          "depends_on": ["fetch-data"],
          "executionType": "bundled"
        },
        {
          "id": "send-notification",
          "agentId": "notifier",
          "description": "Send analysis summary notification",
          "depends_on": ["analyze-data"],
          "executionType": "llm",
          "tools": ["slack", "sendgrid"]
        }
      ],
      "documentContracts": [
        {
          "producerStepId": "fetch-data",
          "documentId": "raw-data",
          "documentType": "data-snapshot",
          "schema": {
            "type": "object",
            "properties": {
              "records": { "type": "array", "items": { "type": "object" } },
              "fetchedAt": { "type": "string" }
            },
            "required": ["records", "fetchedAt"]
          }
        },
        {
          "producerStepId": "analyze-data",
          "documentId": "analysis-result",
          "documentType": "summary",
          "schema": {
            "type": "object",
            "properties": {
              "summary": { "type": "string" },
              "trends": { "type": "array", "items": { "type": "string" } }
            },
            "required": ["summary", "trends"]
          }
        },
        {
          "producerStepId": "send-notification",
          "documentId": "notification-result",
          "documentType": "notification",
          "schema": {
            "type": "object",
            "properties": { "sent": { "type": "boolean" }, "channel": { "type": "string" } },
            "required": ["sent", "channel"]
          }
        }
      ],
      "prepareMappings": [
        {
          "consumerStepId": "analyze-data",
          "documentId": "raw-data",
          "documentType": "data-snapshot",
          "sources": [{ "from": "records", "to": "input_data" }],
          "constants": []
        },
        {
          "consumerStepId": "send-notification",
          "documentId": "analysis-result",
          "documentType": "summary",
          "sources": [{ "from": "summary", "to": "message" }],
          "constants": [{ "key": "channel", "value": "#data-sync" }]
        }
      ]
    },
    {
      "id": "process-webhook",
      "name": "Process Webhook",
      "title": "Handle Webhook Payload",
      "triggerSignalId": "webhook-received",
      "steps": [
        {
          "id": "parse-payload",
          "agentId": "data-analyst",
          "description": "Parse and validate the incoming webhook payload",
          "depends_on": [],
          "executionType": "bundled"
        },
        {
          "id": "send-response",
          "agentId": "notifier",
          "description": "Send acknowledgement notification",
          "depends_on": ["parse-payload"],
          "executionType": "llm",
          "tools": ["slack", "sendgrid"]
        }
      ],
      "documentContracts": [
        {
          "producerStepId": "parse-payload",
          "documentId": "parsed-payload",
          "documentType": "payload",
          "schema": {
            "type": "object",
            "properties": { "event": { "type": "string" }, "data": { "type": "object" } },
            "required": ["event", "data"]
          }
        },
        {
          "producerStepId": "send-response",
          "documentId": "response-result",
          "documentType": "notification",
          "schema": {
            "type": "object",
            "properties": { "sent": { "type": "boolean" }, "channel": { "type": "string" } },
            "required": ["sent", "channel"]
          }
        }
      ],
      "prepareMappings": [
        {
          "consumerStepId": "send-response",
          "documentId": "parsed-payload",
          "documentType": "payload",
          "sources": [{ "from": "event", "to": "subject" }, { "from": "data", "to": "body" }],
          "constants": [{ "key": "channel", "value": "#webhooks" }]
        }
      ]
    }
  ]
}
