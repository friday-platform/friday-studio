{
  "workspace": {
    "name": "meeting-notes-distribution",
    "purpose": "Summarize meeting notes with action items and distribute via Slack"
  },
  "signals": [
    {
      "id": "meeting-ended",
      "name": "Meeting Recording Available",
      "title": "Process meeting notes",
      "signalType": "http",
      "description": "Triggered when a meeting recording/transcript becomes available",
      "signalConfig": { "provider": "http", "config": { "path": "/webhook/meeting-ended" } },
      "payloadSchema": {
        "type": "object",
        "properties": {
          "meeting_id": { "type": "string", "description": "Meeting identifier" },
          "artifact_ref": {
            "type": "string",
            "description": "Artifact reference to the transcript"
          },
          "channel": { "type": "string", "description": "Slack channel to post notes to" }
        },
        "required": ["meeting_id", "artifact_ref", "channel"]
      }
    }
  ],
  "agents": [
    {
      "id": "fathom-get-transcript",
      "name": "Transcript Fetcher",
      "description": "Fetches the meeting transcript from Fathom",
      "capabilities": ["fathom-get-transcript"]
    },
    {
      "id": "get-summary",
      "name": "Notes Summarizer",
      "description": "Summarizes the transcript into notes with action items",
      "capabilities": ["get-summary"]
    },
    {
      "id": "slack",
      "name": "Notes Distributor",
      "description": "Posts the meeting summary and action items to the team Slack channel",
      "capabilities": ["slack"]
    }
  ],
  "jobs": [
    {
      "id": "process-meeting",
      "name": "Process Meeting Notes",
      "title": "Meeting Notes",
      "triggerSignalId": "meeting-ended",
      "steps": [
        {
          "id": "fetch-transcript",
          "agentId": "fathom-get-transcript",
          "description": "Fetch the meeting transcript from Fathom",
          "depends_on": [],
          "executionType": "bundled"
        },
        {
          "id": "summarize-notes",
          "agentId": "get-summary",
          "description": "Create a summary with key decisions, action items, and owners",
          "depends_on": ["fetch-transcript"],
          "executionType": "bundled"
        },
        {
          "id": "post-notes",
          "agentId": "slack",
          "description": "Post the meeting summary to the designated Slack channel",
          "depends_on": ["summarize-notes"],
          "executionType": "bundled"
        }
      ],
      "documentContracts": [
        {
          "producerStepId": "fetch-transcript",
          "documentId": "transcript",
          "documentType": "transcript",
          "schema": {
            "type": "object",
            "properties": {
              "response": { "type": "string", "description": "Meeting title and full transcript" }
            },
            "required": ["response"]
          }
        },
        {
          "producerStepId": "summarize-notes",
          "documentId": "meeting-summary",
          "documentType": "summary",
          "schema": {
            "type": "object",
            "properties": {
              "summary": { "type": "string", "description": "Meeting summary with key decisions" },
              "action_items": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "task": { "type": "string", "description": "Action item description" },
                    "owner": { "type": "string", "description": "Person responsible" }
                  },
                  "required": ["task", "owner"]
                }
              }
            },
            "required": ["summary", "action_items"]
          }
        },
        {
          "producerStepId": "post-notes",
          "documentId": "slack-result",
          "documentType": "slack-result",
          "schema": {
            "type": "object",
            "properties": {
              "response": { "type": "string", "description": "Slack post confirmation" }
            },
            "required": ["response"]
          }
        }
      ],
      "prepareMappings": [
        {
          "consumerStepId": "summarize-notes",
          "documentId": "transcript",
          "documentType": "transcript",
          "sources": [{ "from": "response", "to": "content" }],
          "constants": [{ "key": "output_format", "value": "meeting_notes" }]
        },
        {
          "consumerStepId": "post-notes",
          "documentId": "transcript",
          "documentType": "transcript",
          "sources": [{ "from": "response", "to": "message" }],
          "constants": [{ "key": "channel", "value": "#team" }]
        }
      ]
    }
  ]
}
