{
  "workspace": {
    "name": "ticket-automation",
    "purpose": "Read a support ticket, implement the requested changes, and update the ticket with results"
  },
  "signals": [
    {
      "id": "ticket-assigned",
      "name": "Ticket Assigned",
      "title": "Process assigned ticket",
      "signalType": "http",
      "description": "Triggered when a new ticket is assigned for automated processing",
      "signalConfig": { "provider": "http", "config": { "path": "/webhook/ticket-assigned" } },
      "payloadSchema": {
        "type": "object",
        "properties": {
          "ticket_id": { "type": "string", "description": "External ticket system identifier" },
          "ticket_url": {
            "type": "string",
            "description": "URL to the ticket in the external system"
          },
          "repo": {
            "type": "string",
            "description": "Repository in owner/repo format for code changes"
          }
        },
        "required": ["ticket_id", "ticket_url", "repo"]
      }
    }
  ],
  "agents": [
    {
      "id": "ticket-reader",
      "name": "Ticket Reader",
      "description": "Reads and parses a support ticket to extract the requested changes and acceptance criteria",
      "needs": ["ticket-system-access", "text-extraction"]
    },
    {
      "id": "claude-code",
      "name": "Code Implementer",
      "description": "Implements the code changes described in the ticket using Claude Code with sandboxed filesystem access",
      "needs": ["code-generation", "file-operations"]
    },
    {
      "id": "ticket-updater",
      "name": "Ticket Updater",
      "description": "Updates the ticket with implementation results and status",
      "needs": ["ticket-system-access", "status-reporting"]
    }
  ],
  "jobs": [
    {
      "id": "process-ticket",
      "name": "Process Support Ticket",
      "title": "Ticket Processing",
      "triggerSignalId": "ticket-assigned",
      "steps": [
        {
          "id": "read-ticket",
          "agentId": "ticket-reader",
          "description": "Read the assigned ticket and extract the task description, acceptance criteria, and relevant context",
          "depends_on": [],
          "executionType": "llm",
          "tools": ["linear"]
        },
        {
          "id": "implement-changes",
          "agentId": "claude-code",
          "description": "Implement the code changes described in the ticket within the specified repository",
          "depends_on": ["read-ticket"],
          "executionType": "bundled"
        },
        {
          "id": "update-ticket",
          "agentId": "ticket-updater",
          "description": "Update the ticket with the implementation results, files changed, and completion status",
          "depends_on": ["implement-changes"],
          "executionType": "llm",
          "tools": ["linear"]
        }
      ],
      "documentContracts": [
        {
          "producerStepId": "read-ticket",
          "documentId": "ticket-details",
          "documentType": "ticket",
          "schema": {
            "type": "object",
            "properties": {
              "title": { "type": "string", "description": "Ticket title" },
              "description": { "type": "string", "description": "Full ticket description" },
              "acceptance_criteria": {
                "type": "array",
                "items": { "type": "string" },
                "description": "List of acceptance criteria to satisfy"
              },
              "priority": {
                "type": "string",
                "enum": ["low", "medium", "high", "critical"],
                "description": "Ticket priority level"
              }
            },
            "required": ["title", "description", "acceptance_criteria", "priority"]
          }
        },
        {
          "producerStepId": "implement-changes",
          "documentId": "implementation-result",
          "documentType": "code-result",
          "schema": {
            "type": "object",
            "properties": {
              "response": { "type": "string", "description": "Claude Code output text" }
            },
            "required": ["response"]
          }
        },
        {
          "producerStepId": "update-ticket",
          "documentId": "ticket-update-confirmation",
          "documentType": "status",
          "schema": {
            "type": "object",
            "properties": {
              "ticket_id": {
                "type": "string",
                "description": "Ticket identifier that was updated"
              },
              "status": {
                "type": "string",
                "enum": ["completed", "failed", "needs-review"],
                "description": "Final ticket status"
              },
              "comment": { "type": "string", "description": "Summary comment posted to the ticket" }
            },
            "required": ["ticket_id", "status", "comment"]
          }
        }
      ],
      "prepareMappings": [
        {
          "consumerStepId": "implement-changes",
          "documentId": "ticket-details",
          "documentType": "ticket",
          "sources": [
            { "from": "description", "to": "task" },
            { "from": "acceptance_criteria", "to": "requirements" }
          ],
          "constants": []
        },
        {
          "consumerStepId": "update-ticket",
          "documentId": "implementation-result",
          "documentType": "code-result",
          "sources": [{ "from": "response", "to": "implementation_summary" }],
          "constants": [{ "key": "action", "value": "resolve" }]
        }
      ]
    }
  ]
}
