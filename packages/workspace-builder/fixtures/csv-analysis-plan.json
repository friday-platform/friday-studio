{
  "workspace": {
    "name": "csv-analysis-reporter",
    "purpose": "Analyze uploaded CSV data and email a summary report"
  },
  "signals": [
    {
      "id": "csv-uploaded",
      "name": "CSV File Uploaded",
      "title": "Analyze uploaded CSV",
      "signalType": "http",
      "description": "Triggered when a user uploads a CSV file for analysis via the HTTP endpoint",
      "signalConfig": { "provider": "http", "config": { "path": "/webhook/csv-uploaded" } },
      "payloadSchema": {
        "type": "object",
        "properties": {
          "artifact_ref": {
            "type": "string",
            "description": "Artifact reference ID for the uploaded CSV database"
          },
          "question": {
            "type": "string",
            "description": "Analysis question to answer from the data"
          },
          "recipient_email": {
            "type": "string",
            "description": "Email address to send the report to"
          }
        },
        "required": ["artifact_ref", "question", "recipient_email"]
      }
    }
  ],
  "agents": [
    {
      "id": "data-analyst",
      "name": "Data Analyst",
      "description": "Analyzes tabular data using SQL queries to answer questions and produce actionable insights",
      "needs": ["data-analysis", "sql"]
    },
    {
      "id": "email",
      "name": "Email Reporter",
      "description": "Composes and sends an email report with the analysis results",
      "needs": ["email", "sendgrid"]
    }
  ],
  "jobs": [
    {
      "id": "analyze-and-report",
      "name": "Analyze CSV and Email Report",
      "title": "CSV Analysis Report",
      "triggerSignalId": "csv-uploaded",
      "steps": [
        {
          "id": "analyze-csv",
          "agentId": "data-analyst",
          "description": "Run SQL analysis on the uploaded CSV data to answer the user's question",
          "depends_on": [],
          "executionType": "bundled"
        },
        {
          "id": "send-report",
          "agentId": "email",
          "description": "Email the analysis summary and key findings to the specified recipient",
          "depends_on": ["analyze-csv"],
          "executionType": "bundled"
        }
      ],
      "documentContracts": [
        {
          "producerStepId": "analyze-csv",
          "documentId": "analysis-output",
          "documentType": "summary",
          "schema": {
            "type": "object",
            "properties": {
              "summary": { "type": "string", "description": "Analysis narrative" },
              "queries": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "sql": { "type": "string" },
                    "success": { "type": "boolean" },
                    "rowCount": { "type": "number" },
                    "error": { "type": "string" },
                    "durationMs": { "type": "number" },
                    "tool": { "type": "string", "enum": ["execute_sql", "save_results"] }
                  },
                  "required": ["sql", "success", "rowCount", "error", "durationMs", "tool"]
                }
              }
            },
            "required": ["summary", "queries"]
          }
        },
        {
          "producerStepId": "send-report",
          "documentId": "email-confirmation",
          "documentType": "email-result",
          "schema": {
            "type": "object",
            "properties": {
              "response": { "type": "string", "description": "Email send confirmation" },
              "message_id": { "type": "string", "description": "SendGrid message ID" }
            },
            "required": ["response"]
          }
        }
      ],
      "prepareMappings": [
        {
          "consumerStepId": "send-report",
          "documentId": "analysis-output",
          "documentType": "summary",
          "sources": [
            { "from": "summary", "to": "report_body" },
            { "from": "queries", "to": "query_log" }
          ],
          "constants": [{ "key": "subject_prefix", "value": "[CSV Analysis]" }]
        }
      ]
    }
  ]
}
