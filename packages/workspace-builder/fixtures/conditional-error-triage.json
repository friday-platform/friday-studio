{
  "workspace": {
    "name": "error-triage-automation",
    "purpose": "Analyze error trends and route to different channels based on severity"
  },
  "signals": [
    {
      "id": "weekly-error-review",
      "name": "Weekly Error Review",
      "title": "Triage error trends",
      "signalType": "schedule",
      "description": "Fires weekly to analyze error trends and route alerts",
      "signalConfig": {
        "provider": "schedule",
        "config": { "schedule": "0 9 * * 1", "timezone": "America/Denver" }
      }
    }
  ],
  "agents": [
    {
      "id": "data-analyst",
      "name": "Error Trend Analyzer",
      "description": "Analyzes error logs to identify frequency trends and severity",
      "capabilities": ["data-analyst"]
    },
    {
      "id": "slack",
      "name": "Critical Alert Poster",
      "description": "Posts critical error alerts to the #incidents channel",
      "capabilities": ["slack"]
    },
    {
      "id": "email",
      "name": "Routine Report Sender",
      "description": "Emails a routine error trend report for non-critical patterns",
      "capabilities": ["email"]
    }
  ],
  "jobs": [
    {
      "id": "triage-errors",
      "name": "Triage Error Trends",
      "title": "Error Triage",
      "triggerSignalId": "weekly-error-review",
      "steps": [
        {
          "id": "analyze-errors",
          "agentId": "data-analyst",
          "executionRef": "data-analyst",
          "description": "Analyze error logs, compute trends, and determine severity level",
          "depends_on": [],
          "executionType": "bundled"
        },
        {
          "id": "alert-critical",
          "agentId": "slack",
          "executionRef": "slack",
          "description": "Post critical error summary to #incidents Slack channel",
          "depends_on": ["analyze-errors"],
          "executionType": "bundled"
        },
        {
          "id": "report-routine",
          "agentId": "email",
          "executionRef": "email",
          "description": "Send routine error trend report via email",
          "depends_on": ["analyze-errors"],
          "executionType": "bundled"
        }
      ],
      "documentContracts": [
        {
          "producerStepId": "analyze-errors",
          "documentId": "error-analysis",
          "documentType": "summary",
          "schema": {
            "type": "object",
            "properties": {
              "summary": { "type": "string", "description": "Error trend analysis narrative" },
              "queries": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "sql": { "type": "string" },
                    "success": { "type": "boolean" },
                    "rowCount": { "type": "number" },
                    "error": { "type": "string" },
                    "durationMs": { "type": "number" },
                    "tool": { "type": "string", "enum": ["execute_sql", "save_results"] }
                  },
                  "required": ["sql", "success", "rowCount", "error", "durationMs", "tool"]
                }
              }
            },
            "required": ["summary", "queries"]
          }
        },
        {
          "producerStepId": "alert-critical",
          "documentId": "slack-alert",
          "documentType": "slack-result",
          "schema": {
            "type": "object",
            "properties": {
              "response": { "type": "string", "description": "Slack alert confirmation" }
            },
            "required": ["response"]
          }
        },
        {
          "producerStepId": "report-routine",
          "documentId": "email-report",
          "documentType": "email-result",
          "schema": {
            "type": "object",
            "properties": {
              "response": { "type": "string", "description": "Email send confirmation" }
            },
            "required": ["response"]
          }
        }
      ],
      "prepareMappings": [
        {
          "consumerStepId": "alert-critical",
          "documentId": "error-analysis",
          "documentType": "summary",
          "sources": [{ "from": "summary", "to": "message" }],
          "constants": [{ "key": "channel", "value": "#incidents" }]
        },
        {
          "consumerStepId": "report-routine",
          "documentId": "error-analysis",
          "documentType": "summary",
          "sources": [{ "from": "summary", "to": "body" }],
          "constants": [
            { "key": "subject", "value": "Weekly Error Trend Report" },
            { "key": "to", "value": "engineering@example.com" }
          ]
        }
      ],
      "conditionals": [
        {
          "stepId": "analyze-errors",
          "field": "summary",
          "branches": [
            { "equals": "critical", "targetStep": "alert-critical" },
            { "default": true, "targetStep": "report-routine" }
          ]
        }
      ]
    }
  ]
}
