{
  "workspace": {
    "name": "email-inbox-summary",
    "purpose": "Summarize unread emails and post highlights to Slack every morning"
  },
  "signals": [
    {
      "id": "morning-trigger",
      "name": "Morning Schedule",
      "title": "Daily inbox digest",
      "signalType": "schedule",
      "description": "Fires every weekday morning at 8am to trigger inbox summarization",
      "signalConfig": {
        "provider": "schedule",
        "config": { "schedule": "0 8 * * 1-5", "timezone": "America/Denver" }
      }
    }
  ],
  "agents": [
    {
      "id": "email",
      "name": "Email Reader",
      "description": "Reads unread emails from the last 24 hours",
      "capabilities": ["google-gmail"]
    },
    {
      "id": "get-summary",
      "name": "Inbox Summarizer",
      "description": "Summarizes email subjects and highlights urgent items",
      "capabilities": ["get-summary"]
    },
    {
      "id": "slack",
      "name": "Slack Poster",
      "description": "Posts the daily inbox summary to a designated Slack channel",
      "capabilities": ["slack"]
    }
  ],
  "jobs": [
    {
      "id": "daily-inbox-digest",
      "name": "Daily Inbox Digest",
      "title": "Inbox Digest",
      "triggerSignalId": "morning-trigger",
      "steps": [
        {
          "id": "read-inbox",
          "agentId": "email",
          "description": "Fetch unread emails from the last 24 hours",
          "depends_on": [],
          "executionType": "bundled"
        },
        {
          "id": "summarize-inbox",
          "agentId": "get-summary",
          "description": "Summarize the emails, grouping by urgency and topic",
          "depends_on": ["read-inbox"],
          "executionType": "bundled"
        },
        {
          "id": "post-to-slack",
          "agentId": "slack",
          "description": "Post the digest to the #daily-updates Slack channel",
          "depends_on": ["summarize-inbox"],
          "executionType": "bundled"
        }
      ],
      "documentContracts": [
        {
          "producerStepId": "read-inbox",
          "documentId": "inbox-emails",
          "documentType": "email-list",
          "schema": {
            "type": "object",
            "properties": {
              "response": { "type": "string", "description": "Email read results" },
              "message_id": { "type": "string", "description": "SendGrid message ID" },
              "email": {
                "type": "object",
                "properties": {
                  "to": { "type": "string" },
                  "subject": { "type": "string" },
                  "content": { "type": "string" },
                  "from": { "type": "string" }
                }
              }
            },
            "required": ["response"]
          }
        },
        {
          "producerStepId": "summarize-inbox",
          "documentId": "inbox-summary",
          "documentType": "summary",
          "schema": {
            "type": "object",
            "properties": {
              "digest": {
                "type": "string",
                "description": "Formatted inbox digest grouped by urgency and topic"
              },
              "urgent_count": {
                "type": "number",
                "description": "Number of urgent emails identified"
              }
            },
            "required": ["digest", "urgent_count"]
          }
        },
        {
          "producerStepId": "post-to-slack",
          "documentId": "slack-confirmation",
          "documentType": "slack-result",
          "schema": {
            "type": "object",
            "properties": {
              "response": { "type": "string", "description": "Slack post confirmation" }
            },
            "required": ["response"]
          }
        }
      ],
      "prepareMappings": [
        {
          "consumerStepId": "summarize-inbox",
          "documentId": "inbox-emails",
          "documentType": "email-list",
          "sources": [{ "from": "response", "to": "email_content" }],
          "constants": [{ "key": "format", "value": "digest" }]
        },
        {
          "consumerStepId": "post-to-slack",
          "documentId": "inbox-emails",
          "documentType": "email-list",
          "sources": [{ "from": "response", "to": "message" }],
          "constants": [{ "key": "channel", "value": "#daily-updates" }]
        }
      ]
    }
  ]
}
