{
  "$schema": "https://biomejs.dev/schemas/2.4.1/schema.json",
  "vcs": { "enabled": false, "clientKind": "git", "useIgnoreFile": false },
  "files": {
    "ignoreUnknown": false,
    "includes": [
      "**",
      "!**/.atlas",
      "!**/.beads",
      "!**/.svelte-kit",
      "!**/build",
      "!**/.vite",
      "!**/dist",
      "!**/dist-tauri",
      "!**/target",
      "!**/node_modules",
      "!**/vendor",
      "!packages/vendor",
      "!apps/web-client",
      "!apps/atlas-auth-ui",
      "!opensrc"
    ]
  },
  "html": { "parser": { "interpolation": true } },
  "formatter": {
    "enabled": true,
    "formatWithErrors": false,
    "attributePosition": "auto",
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100,
    "expand": "never"
  },
  "assist": { "enabled": true, "actions": { "source": { "organizeImports": "on" } } },
  "overrides": [
    {
      "includes": ["**/*.svelte"],
      "linter": {
        "rules": {
          "style": { "useConst": "off", "useImportType": "off" },
          "correctness": { "noUnusedVariables": "off", "noUnusedImports": "off" }
        }
      }
    }
  ]
}
