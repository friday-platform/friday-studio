{
  "$schema": "https://raw.githubusercontent.com/denoland/deno/main/cli/schemas/config-file.v1.json",
  "version": "1.0.0",
  "workspace": ["./apps/*", "./packages/*", "./tools/evals", "./tools/agent-playground"],
  "compilerOptions": {
    "lib": ["deno.window", "deno.worker", "deno.unstable", "dom", "dom.iterable"],
    "types": ["./reset.d.ts"],
    "noImplicitAny": true,
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "jsx": "react-jsx",
    "jsxImportSource": "react"
  },
  "exclude": [
    "!integration-tests/**/*.test.ts",
    "tools/agent-playground/.svelte-kit",
    "tools/agent-playground/src/routes/**",
    "tools/agent-playground/src/**/*.svelte.ts",
    "tools/agent-playground/src/lib/inspector-state.test.ts",
    "tools/agent-playground/src/lib/editor/**",
    "tools/agent-playground/src/lib/queries/**",
    "tools/agent-playground/src/lib/stores/**",
    "tools/agent-playground/src/lib/utils/markdown.ts",
    "opensrc",
    "types"
  ],
  "unstable": ["worker-options", "otel", "kv", "raw-imports"],
  "nodeModulesDir": "none",
  "lint": { "rules": { "tags": ["recommended"] }, "exclude": ["opensrc/**"] },
  "imports": {
    "@std/assert": "jsr:@std/assert@^1.0.16",
    "@std/async": "jsr:@std/async@^1.0.15",
    "@std/dotenv": "jsr:@std/dotenv@^0.225.5",
    "@std/encoding": "jsr:@std/encoding@1.0.10",
    "@std/media-types": "jsr:@std/media-types@^1.1.0",
    "@std/tar": "jsr:@std/tar@^0.1.9",
    "@std/testing": "jsr:@std/testing@^1.0.16",
    "@std/yaml": "jsr:@std/yaml@^1",
    "cookie": "npm:cookie@^1.0.2",
    "@sendgrid/helpers": "npm:@sendgrid/helpers@^8.0.0",
    "hono/client": "npm:hono@4.12.15/client",
    "jose": "npm:jose@^6.1.3",
    "nanoid": "npm:nanoid@^5.1.6",
    "openapi-fetch": "npm:openapi-fetch@^0.15.0",
    "cron-parser": "npm:cron-parser@^5.5.0",
    "@atlas/fsm-engine": "./packages/fsm-engine/mod.ts",
    "@atlas/resources": "./packages/resources/src/mod.ts",
    "@atlas/resources/guidance": "./packages/resources/src/guidance.ts",
    "@atlas/activity": "./packages/activity/src/mod.ts",
    "@atlas/activity/titles": "./packages/activity/src/title-utils.ts",
    "@atlas/activity/title-generator": "./packages/activity/src/title-generator.ts",
    "@atlas/activity/local-adapter": "./packages/activity/src/local-adapter.ts",
    "@atlas/resources/types": "./packages/resources/src/types.ts"
  },
  "allowScripts": [
    "npm:@launchql/protobufjs@7.2.6",
    "npm:better-sqlite3@12.6.2",
    "npm:esbuild@0.27.1",
    "npm:esbuild@0.27.2",
    "npm:esbuild@0.27.3",
    "npm:fsevents@2.3.3",
    "npm:protobufjs@7.5.4",
    "npm:protobufjs@8.0.0"
  ]
}
