# Development files
.git/
.gitignore
.env*
!.env.ci

# Documentation and non-essential files
*.md
docs/
REASONING_FIXES.md
GETTING_STARTED.md

# Test files
**/tests/
**/*.test.ts
**/test/
coverage/

# Development tools and configs
.vscode/
.idea/
*.swp
*.swo
*~

# Apps with their own Dockerfiles (separate build pipelines)
apps/friday-website/

# Node modules (if any)
node_modules/

# Build artifacts and temporary files
build/
dist/
tmp/
temp/
.tmp/
*.tmp
*.log
atlas-daemon.log
atlas-test.log
.svelte-kit/

# OS files
.DS_Store
Thumbs.db

# Development scripts
scripts/

# Examples shipped separately (zip download), not baked into Docker image
examples/
specs/

# Compiled binaries (we'll build fresh in container)
atlas
atlas.exe

# Package manager files from other ecosystems
package-lock.json
yarn.lock
pnpm-lock.yaml
composer.json
requirements.txt
Pipfile
Cargo.toml

# IDE and editor files
*.sublime-*
.vscode/
.idea/
*.iml

# Temporary and cache files
.cache/
.deno/
**/target/
**/.next/
**/.nuxt/
**/coverage/

# Lint and format configs (keep main ones)
lint-staged.config.js

# Go source and configs (not used in Deno builds)
go.mod
go.sum
pkg/
.golangci.yml

# Infrastructure and deployment configs
infra/
supabase/
analytics/

# Editor and CI configs not needed in image
.claude/
.github/
.husky/
.zed/
.editorconfig

# Source code for reference only (not runtime)
opensrc/
