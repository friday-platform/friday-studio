    "@atlas/fsm-engine": "workspace:*",
    "@atlas/hallucination": "workspace:*",
    "@atlas/llm": "workspace:*",
    "@atlas/logger": "workspace:*",
    "@atlas/sentry": "workspace:*",
    "@atlas/memory": "workspace:*",
    "@atlas/oapi-client": "workspace:*",
    "@atlas/signals": "workspace:*",
    "@atlas/storage": "workspace:*",
    "@atlas/system": "workspace:*",
    "@atlas/utils": "workspace:*",
    "@atlas/workspace": "workspace:*",
    "@inkjs/ui": "^2.0.0",
    "@opentelemetry/api": "^1.9.0",
