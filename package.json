    "@std/path": "npm:@jsr/std__path@^1.1.2",
    "@std/yaml": "npm:@jsr/std__yaml@^1.0.10",
    "@types/react": "^19.2.7",
    "ai": "^5.0.118",
    "ink": "^6.6.0",
    "js-levenshtein": "^1.1.6",
    "lint-staged": "^16.2.7",
    "nanoid": "^5.1.6",
    "react": "^19.2.3",
    "yargs": "^18.0.0",
    "zod": "^4.3.5"
