{
  "name": "atlas",
  "version": "1.0.0",
  "type": "module",
  "workspaces": [
    "./apps/*",
    "./packages/*",
    "./packages/vendor/*",
    "./tools/memory_manager",
    "./tools/evals"
  ],
  "scripts": {
    "lint": "deno lint",
    "test": "deno test",
    "test:unit": "deno task test:unit",
    "test:integration": "deno task test:integration",
    "knip": "knip",
    "generate:package-json": "deno run --allow-read --allow-write scripts/generate-package-json.ts"
  },
  "dependencies": {
    "@atlas/agent-sdk": "workspace:*",
    "@atlas/atlasd": "workspace:*",
    "@atlas/client": "workspace:*",
    "@atlas/config": "workspace:*",
    "@atlas/core": "workspace:*",
    "@atlas/logger": "workspace:*",
    "@atlas/mcp": "workspace:*",
    "@atlas/memory": "workspace:*",
    "@atlas/oapi-client": "workspace:*",
    "@atlas/signals": "workspace:*",
    "@atlas/storage": "workspace:*",
    "@atlas/system": "workspace:*",
    "@atlas/utils": "workspace:*",
    "@atlas/workspace": "workspace:*",
    "@inkjs/ui": "^2.0.0",
    "@modelcontextprotocol/sdk": "npm:@socotra/modelcontextprotocol-sdk@^1.18.0",
    "@opentelemetry/api": "^1.9.0",
    "@std/async": "npm:@jsr/std__async@^1.0.14",
    "@std/dotenv": "npm:@jsr/std__dotenv@^0.225.5",
    "@std/fs": "npm:@jsr/std__fs@^1.0.19",
    "@std/path": "npm:@jsr/std__path@^1.1.2",
    "@std/tar": "npm:@jsr/std__tar@^0.1.8",
    "@std/text": "npm:@jsr/std__text@^1.0.16",
    "@std/yaml": "npm:@jsr/std__yaml@^1.0.9",
    "@types/react": "^19.1.13",
    "ai": "^5.0.59",
    "ansi-escapes": "^7.1.0",
    "chalk": "^5.6.2",
    "eventsource-client": "^1.1.4",
    "ink": "^6.3.0",
    "js-levenshtein": "^1.1.6",
    "lint-staged": "^16.1.6",
    "marked": "^16.2.1",
    "marked-terminal": "^7.3.0",
    "react": "^19.1.1",
    "xstate": "^5.21.0",
    "yargs": "^18.0.0",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@std/assert": "npm:@jsr/std__assert@^1.0.14",
    "@std/expect": "npm:@jsr/std__expect@^1.0.17",
    "@std/testing": "npm:@jsr/std__testing@^1.0.15",
    "@total-typescript/ts-reset": "^0.6.1",
    "knip": "^5.64.1"
  }
}
