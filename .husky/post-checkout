#!/bin/bash

# Only on branch checkouts, skip file checkouts
[[ "$3" != "1" ]] && exit 0

# Skip if beads already initialized
[[ -d ".beads" ]] && exit 0

# Initialize beads for new branches
bd init --stealth --quiet 2>/dev/null || true

# Housekeeping
bd --no-daemon doctor --fix --yes --quiet 2>/dev/null || true
