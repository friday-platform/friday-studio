{
  "$schema": "https://raw.githubusercontent.com/denoland/deno/main/cli/schemas/config-file.v1.json",
  "version": "1.0.0",
  "workspace": ["./apps/*", "./packages/*", "./tools/memory_manager"],
  "compilerOptions": {
    "lib": [
      "deno.window",
      "deno.worker",
      "deno.unstable",
      "dom",
      "dom.iterable"
    ],
    "types": [],
    "noImplicitAny": false,
    "strict": false,
    "jsx": "react-jsx",
    "jsxImportSource": "react"
  },
  "unstable": ["broadcast-channel", "worker-options", "otel", "kv"],
  "tasks": {
    "prepare": "deno run -A  npm:husky@^9",
    "lint-staged": "deno run -A npm:lint-staged@^16",
    "atlas": "cd \"$INIT_CWD\" && OTEL_DENO=true OTEL_SERVICE_NAME=atlas OTEL_SERVICE_VERSION=1.0.0 OTEL_RESOURCE_ATTRIBUTES=service.name=atlas,service.version=1.0.0 deno run -q --allow-all --unstable-broadcast-channel --unstable-worker-options --unstable-otel --unstable-kv --env-file \"$(git rev-parse --show-toplevel)/src/cli.tsx\"",
    "atlas-no-otel": "cd \"$INIT_CWD\" && deno run --allow-all --unstable-broadcast-channel --unstable-worker-options --unstable-kv --env-file \"$(git rev-parse --show-toplevel)/src/cli.tsx\"",
    "dev": "OTEL_DENO=true deno run --allow-all --watch src/cli.tsx",
    "start": "OTEL_DENO=true deno run --allow-all src/cli.tsx",
    "test": "OTEL_DENO=true deno test --allow-all --env-file --no-check",
    "test:unit": "OTEL_DENO=true deno test --allow-all --env-file --no-check --ignore='integration-tests/**/*.test.ts' --ignore='packages/mcp/tests/manager.test.ts' --ignore='packages/core/test/llm-provider.test.ts'",
    "test:integration": "OTEL_DENO=true ATLAS_USE_LLM_MOCKS=true deno test --allow-all --env-file --no-check 'integration-tests/**/*.test.ts' 'packages/mcp/tests/manager.test.ts' 'packages/core/test/llm-provider.test.ts'",
    "fmt": "deno fmt",
    "lint": "deno lint",
    "example-acp-server": "deno run --allow-net --allow-env examples/workspaces/remote-agents/server.ts",
    "example-playwright-mcp-server": "deno run --allow-all --unstable-broadcast-channel --unstable-worker-options examples/workspaces/playwright-mcp/server.ts",
    "mock-mcp-weather": "deno run --allow-all integration-tests/mocks/weather-mcp-server.ts",
    "mock-mcp-file-tools": "deno run --allow-all integration-tests/mocks/file-tools-mcp-server.ts",
    "mock-mcp-echo": "deno run --allow-all integration-tests/mocks/echo-mcp-server.ts",
    "clean": "deno run --allow-read --allow-write --allow-env scripts/clean.ts",
    "validate-imports": "deno run --allow-read --allow-write scripts/validate-imports.ts",
    "validate-imports-staged": "deno run --allow-read --allow-write --allow-run scripts/validate-imports-staged.ts"
  },
  "imports": {
    "@hono/swagger-ui": "npm:@hono/swagger-ui@^0.5.2",
    "@modelcontextprotocol/sdk": "npm:@modelcontextprotocol/sdk@^1.15.0",
    "@opentelemetry/api": "npm:@opentelemetry/api@^1.9.0",
    "@scalar/hono-api-reference": "npm:@scalar/hono-api-reference@^0.9.9",
    "@std/assert": "jsr:@std/assert@^1.0.13",
    "@std/expect": "jsr:@std/expect@^1.0.16",
    "@std/fs": "jsr:@std/fs@^1.0.19",
    "@std/path": "jsr:@std/path@^1.1.1",
    "@std/async": "jsr:@std/async@^1.0.0",
    "@std/dotenv": "jsr:@std/dotenv@^0.225.0",
    "@std/yaml": "jsr:@std/yaml@^1.0.7",
    "chalk": "npm:chalk@^5.4.1",
    "fullscreen-ink": "npm:fullscreen-ink@^0.0.2",
    "ink": "npm:ink@^6.0.1",
    "js-levenshtein": "npm:js-levenshtein@^1.1.6",
    "lint-staged": "npm:lint-staged@^16.1.2",
    "marked": "npm:marked@^16.0.0",
    "marked-terminal": "npm:marked-terminal@^7.3.0",
    "openapi-fetch": "npm:openapi-fetch@^0.14.0",
    "playwright": "npm:playwright@^1.54.1",
    "react": "npm:react@^19.1.0",
    "@types/react": "npm:@types/react@^19.1.8",
    "meow": "npm:meow@^13.2.0",
    "ai": "npm:ai@^4.0.7",
    "@ai-sdk/anthropic": "npm:@ai-sdk/anthropic@^1.0.2",
    "@ai-sdk/openai": "npm:@ai-sdk/openai@^1.0.8",
    "@ai-sdk/google": "npm:@ai-sdk/google@^1.2.22",
    "xstate": "npm:xstate@^5.20.1",
    "zod": "npm:zod@^3.25.74",
    "@inkjs/ui": "npm:@inkjs/ui@^2.0.0",
    "hono": "npm:hono@^4.8.4",
    "hono/cors": "npm:hono@^4.8.4/cors",
    "hono/logger": "npm:hono@^4.8.4/logger",
    "hono/pretty-json": "npm:hono@^4.8.4/pretty-json",
    "hono/http-exception": "npm:hono@^4.8.4/http-exception",
    "hono/streaming": "npm:hono@^4.8.4/streaming",
    "hono-openapi": "npm:hono-openapi@~0.4.8",
    "@hono/zod-validator": "npm:@hono/zod-validator@^0.4.3",
    "zod-openapi": "npm:zod-openapi@^4.0.0",
    "eventsource-parser": "npm:eventsource-parser@^3.0.3",
    "cron-parser": "npm:cron-parser@^5.3.0",
    "yargs": "https://deno.land/x/yargs@v18.0.0-deno/deno.ts",
    "@atlas/client": "./packages/client/mod.ts",
    "@atlas/config": "./packages/config/mod.ts",
    "@atlas/storage": "./packages/storage/mod.ts",
    "@atlas/reasoning": "./packages/reasoning/mod.ts",
    "@atlas/signals": "./packages/signals/mod.ts"
  },
  "fmt": {
    "lineWidth": 100
  },
  "lint": {
    "rules": {
      "tags": ["recommended"]
    }
  }
}
