{
  "$schema": "https://raw.githubusercontent.com/denoland/deno/main/cli/schemas/config-file.v1.json",
  "version": "1.0.0",
  "exports": "./mod.ts",
  "compilerOptions": {
    "lib": [
      "deno.window",
      "deno.worker",
      "deno.unstable",
      "dom",
      "dom.iterable"
    ],
    "types": [],
    "noImplicitAny": false,
    "strict": false,
    "jsx": "react-jsx",
    "jsxImportSource": "react"
  },
  "unstable": ["broadcast-channel", "worker-options", "otel"],
  "tasks": {
    "prepare": "deno run -A  npm:husky@^9",
    "lint-staged": "deno run -A npm:lint-staged@^16",
    "atlas": "cd \"$INIT_CWD\" && OTEL_DENO=true OTEL_SERVICE_NAME=atlas OTEL_SERVICE_VERSION=1.0.0 OTEL_RESOURCE_ATTRIBUTES=service.name=atlas,service.version=1.0.0 deno run -q --allow-all --unstable-broadcast-channel --unstable-worker-options --unstable-otel --env-file \"$(git rev-parse --show-toplevel)/src/cli.tsx\"",
    "atlas-no-otel": "cd \"$INIT_CWD\" && deno run --allow-all --unstable-broadcast-channel --unstable-worker-options --env-file \"$(git rev-parse --show-toplevel)/src/cli.tsx\"",
    "dev": "OTEL_DENO=true deno run --allow-all --watch src/cli.tsx",
    "start": "OTEL_DENO=true deno run --allow-all src/cli.tsx",
    "test": "OTEL_DENO=true deno test --allow-all --env-file",
    "fmt": "deno fmt",
    "lint": "deno lint",
    "example-acp-server": "deno run --allow-net --allow-env examples/workspaces/remote-agents/server.ts",
    "example-playwright-mcp-server": "deno run --allow-all --unstable-broadcast-channel --unstable-worker-options examples/workspaces/playwright-mcp/server.ts",
    "test-mcp-weather": "deno run --allow-all tests/mocks/weather-mcp-server.ts",
    "test-mcp-file-tools": "deno run --allow-all tests/mocks/file-tools-mcp-server.ts",
    "test-mcp-echo": "deno run --allow-all tests/mocks/echo-mcp-server.ts"
  },
  "imports": {
    "@modelcontextprotocol/sdk": "npm:@modelcontextprotocol/sdk@^1.12.1",
    "@opentelemetry/api": "npm:@opentelemetry/api@^1.9.0",
    "@std/assert": "jsr:@std/assert@^1.0.13",
    "@std/expect": "jsr:@std/expect@^1.0.16",
    "@std/fs": "jsr:@std/fs@^1.0.0",
    "@std/path": "jsr:@std/path@^1.1.0",
    "@std/async": "jsr:@std/async@^1.0.0",
    "@std/dotenv": "jsr:@std/dotenv@^0.225.0",
    "@std/yaml": "jsr:@std/yaml@^1.0.7",
    "fullscreen-ink": "npm:fullscreen-ink@^0.0.2",
    "ink": "npm:ink@^5.0.1",
    "js-levenshtein": "npm:js-levenshtein@^1.1.6",
    "lint-staged": "npm:lint-staged@^16.1.2",
    "openapi-fetch": "npm:openapi-fetch@^0.14.0",
    "openapi-typescript": "npm:openapi-typescript@^7.8.0",
    "react": "npm:react@^18.3.1",
    "@types/react": "npm:@types/react@^18.3.3",
    "meow": "npm:meow@^13.2.0",
    "ai": "npm:ai@^4.0.7",
    "@ai-sdk/anthropic": "npm:@ai-sdk/anthropic@^1.0.2",
    "@ai-sdk/openai": "npm:@ai-sdk/openai@^1.0.8",
    "@ai-sdk/google": "npm:@ai-sdk/google@^1.0.14",
    "xstate": "npm:xstate@^5.18.0",
    "zod": "npm:zod@^3.25.62",
    "@inkjs/ui": "npm:@inkjs/ui@^2.0.0",
    "hono": "jsr:@hono/hono@^4.6.9",
    "hono/cors": "jsr:@hono/hono@^4.6.9/cors",
    "hono/logger": "jsr:@hono/hono@^4.6.9/logger",
    "hono/pretty-json": "jsr:@hono/hono@^4.6.9/pretty-json",
    "hono/http-exception": "jsr:@hono/hono@^4.6.9/http-exception",
    "hono/streaming": "jsr:@hono/hono@^4.6.9/streaming",
    "eventsource-parser": "npm:eventsource-parser@^3.0.1",
    "yargs": "https://deno.land/x/yargs@v18.0.0-deno/deno.ts"
  },
  "fmt": {
    "lineWidth": 100
  },
  "lint": {
    "rules": {
      "tags": ["recommended"]
    }
  }
}
