{
  "$schema": "https://raw.githubusercontent.com/denoland/deno/main/cli/schemas/config-file.v1.json",
  "version": "1.0.0",
  "workspace": [
    "./apps/*",
    "./packages/*",
    "./tools/memory_manager",
    "./tools/evals",
    "./tools/typescript-error-report"
  ],
  "compilerOptions": {
    "lib": ["deno.window", "deno.worker", "deno.unstable", "dom", "dom.iterable"],
    "types": ["./reset.d.ts"],
    "noImplicitAny": true,
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "jsx": "react-jsx",
    "jsxImportSource": "react"
  },
  "exclude": [
    "!integration-tests/**/*.test.ts",
    "apps/web-client/.svelte-kit",
    "tools/atlas-installer"
  ],
  "unstable": ["broadcast-channel", "worker-options", "otel", "kv", "raw-imports"],
  "nodeModulesDir": "auto",
  "tasks": {
    "prepare": "deno run -A  npm:husky@^9",
    "lint-staged": "deno run -A npm:lint-staged@^16.1.6",
    "atlas": "cd \"$INIT_CWD\" && OTEL_DENO=true OTEL_SERVICE_NAME=atlas OTEL_SERVICE_VERSION=1.0.0 OTEL_RESOURCE_ATTRIBUTES=service.name=atlas,service.version=1.0.0 deno run -q --allow-all --unstable-broadcast-channel --unstable-worker-options --unstable-kv --unstable-raw-imports --env-file \"$(git rev-parse --show-toplevel)/src/cli.tsx\"",
    "atlas-no-otel": "cd \"$INIT_CWD\" && deno run --allow-all --unstable-broadcast-channel --unstable-worker-options --unstable-kv --unstable-raw-imports --env-file \"$(git rev-parse --show-toplevel)/src/cli.tsx\"",
    "start": "OTEL_DENO=true deno run --allow-all --unstable-raw-imports src/cli.tsx",
    "test": "OTEL_DENO=true deno test --allow-all --unstable-raw-imports --no-check --env-file",
    "test:unit": "OTEL_DENO=true deno test --allow-all --env-file --no-check --ignore='integration-tests/**/*.test.ts'",
    "test:integration": "OTEL_DENO=true ATLAS_USE_LLM_MOCKS=true deno test --allow-all --env-file --no-check 'integration-tests/**/*.test.ts'",
    "fmt": "deno run -A npm:@biomejs/biome format --write",
    "fmt:check": "deno run -A npm:@biomejs/biome format",
    "biome": "deno run -A npm:@biomejs/biome check",
    "lint": "deno lint",
    "example-acp-server": "deno run --allow-net --allow-env examples/workspaces/remote-agents/server.ts",
    "example-playwright-mcp-server": "deno run --allow-all --unstable-broadcast-channel --unstable-worker-options examples/workspaces/playwright-mcp/server.ts",
    "mock-mcp-weather": "deno run --allow-all integration-tests/mocks/weather-mcp-server.ts",
    "mock-mcp-file-tools": "deno run --allow-all integration-tests/mocks/file-tools-mcp-server.ts",
    "mock-mcp-echo": "deno run --allow-all integration-tests/mocks/echo-mcp-server.ts",
    "clean": "deno run --allow-read --allow-write --allow-env scripts/clean.ts",
    "validate-imports": "deno run --allow-read --allow-write scripts/validate-imports.ts",
    "validate-imports-staged": "deno run --allow-read --allow-write --allow-run scripts/validate-imports-staged.ts",
    "compile": "mkdir -p ./dist && deno compile --no-check --allow-read --allow-write --allow-net --allow-env --allow-run --allow-sys --allow-ffi --unstable-broadcast-channel --unstable-worker-options --include=src --include=examples --output ./dist/atlas ./src/cli.tsx",
    "compile:diagnostics": "mkdir -p ./dist && deno compile --no-check --allow-read --allow-write --allow-net --allow-env --allow-run --allow-sys --allow-ffi --unstable-broadcast-channel --unstable-worker-options --include=src --output ./dist/atlas-diagnostics ./apps/diagnostics/src/index.ts",
    "report": "deno task report:knip ; deno task report:typescript",
    "report:knip": "npx knip --reporter markdown --max-issues 0 > reports/knip-report.md",
    "report:typescript": "deno run --allow-all tools/typescript-error-report/src/main.ts"
  },
  "lint": { "rules": { "tags": ["recommended"] } }
}
