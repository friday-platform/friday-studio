{
  "$schema": "https://raw.githubusercontent.com/denoland/deno/main/cli/schemas/config-file.v1.json",
  "version": "1.0.0",
  "workspace": [
    "./apps/*",
    "./packages/*",
    "./tools/evals",
    "./tools/evals-2",
    "./tools/workspace-simulator"
  ],
  "compilerOptions": {
    "lib": ["deno.window", "deno.worker", "deno.unstable", "dom", "dom.iterable"],
    "types": ["./reset.d.ts"],
    "noImplicitAny": true,
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "jsx": "react-jsx",
    "jsxImportSource": "react"
  },
  "exclude": [
    "!integration-tests/**/*.test.ts",
    "apps/web-client/.svelte-kit",
    "apps/web-client/vite.config.ts",
    "apps/atlas-auth-ui/.svelte-kit",
    "apps/atlas-auth-ui/build",
    "apps/atlas-auth-ui/src/**",
    "apps/friday-website/.svelte-kit",
    "apps/friday-website/src/**",
    "apps/atlas-installer",
    "packages/vendor/**",
    "apps/web-client/src-tauri/**",
    "opensrc"
  ],
  "unstable": ["worker-options", "otel", "kv", "raw-imports"],
  "nodeModulesDir": "auto",
  "tasks": {
    "prepare": "deno run -A  npm:husky@^9",
    "lint-staged": "deno run -A npm:lint-staged@^16.2.7",
    "atlas": "deno run -q --allow-all --unstable-worker-options --unstable-kv --unstable-raw-imports --env-file --watch src/cli.tsx",
    "start": "deno run --allow-all --unstable-worker-options --unstable-kv --unstable-raw-imports src/cli.tsx",
    "litellm:start": "docker run -d --name litellm-proxy -p 4000:4000 -v $HOME/.atlas/litellm-config.yaml:/app/config.yaml ghcr.io/berriai/litellm:main-latest --config /app/config.yaml",
    "litellm:stop": "docker stop litellm-proxy && docker rm litellm-proxy",
    "litellm:logs": "docker logs -f litellm-proxy",
    "google-mcp:build": "docker build -t google-workspace-mcp -f apps/google-workspace-mcp/Dockerfile .",
    "google-mcp:start": "docker run -d --name google-workspace-mcp -p 8000:8000 --tmpfs /app/tmp:uid=65534 google-workspace-mcp",
    "google-mcp:stop": "docker stop google-workspace-mcp && docker rm google-workspace-mcp",
    "google-mcp:logs": "docker logs -f google-workspace-mcp",
    "dev": "LINK_DEV_MODE=true deno run -A npm:concurrently -n daemon,link,web -c blue,green,magenta 'deno task atlas daemon start' 'cd apps/link && deno task dev' 'cd apps/web-client && vite dev'",
    "dev:full": "LINK_DEV_MODE=true deno run -A npm:concurrently -n daemon,link,web,gateway,bounce,signal -c blue,green,magenta,yellow,cyan,red 'deno task atlas daemon start' 'cd apps/link && deno task dev' 'cd apps/web-client && npx vite dev' 'PORT=8087 DOT_ENV=$HOME/.atlas/gateway.env go run ./apps/gateway' 'PORT=8083 METRICS_PORT=9091 DOT_ENV=$HOME/.atlas/bounce.env go run ./apps/bounce' 'test -f $HOME/.atlas/signal-gateway.env && PORT=8081 METRICS_PORT=9092 DOT_ENV=$HOME/.atlas/signal-gateway.env go run ./apps/signal-gateway || echo signal-gateway skipped - create ~/.atlas/signal-gateway.env to enable'",
    "test": "OTEL_DENO=true CORTEX_TEST=true DENO_TESTING=true LINK_DEV_MODE=true vitest run",
    "fmt": "deno run -A npm:@biomejs/biome format --write && deno task -f '@atlas/web-client' fmt && deno task -f '@atlas/auth-ui' fmt",
    "fmt:check": "deno run -A npm:@biomejs/biome format && deno task -f '@atlas/web-client' fmt:check && deno task -f '@atlas/auth-ui' fmt:check",
    "biome": "deno run -A npm:@biomejs/biome",
    "lint": "deno lint --fix && deno run -A npm:@biomejs/biome check --write",
    "lint:check": "deno lint && deno run -A npm:@biomejs/biome check --max-diagnostics=200",
    "clean": "deno run -A scripts/clean.ts",
    "compile": "./scripts/compile.sh",
    "sim": "deno run --allow-all tools/workspace-simulator/cli.ts",
    "sim:playground": "deno run --allow-all --watch=tools/workspace-simulator/playground.ts,tools/workspace-simulator/playground.html,tools/workspace-simulator/cli.ts,tools/workspace-simulator/harness/ tools/workspace-simulator/playground.ts"
  },
  "lint": {
    "rules": { "tags": ["recommended"] },
    "exclude": ["packages/vendor/**", "apps/atlas-auth-ui/vite.config.ts", "opensrc/**"]
  },
  "imports": {
    "@std/assert": "jsr:@std/assert@^1.0.16",
    "@std/async": "jsr:@std/async@^1.0.15",
    "@std/dotenv": "jsr:@std/dotenv@^0.225.5",
    "@std/encoding": "jsr:@std/encoding@1.0.10",
    "@std/fs": "jsr:@std/fs@^1.0.20",
    "@std/media-types": "jsr:@std/media-types@^1.1.0",
    "@std/path": "jsr:@std/path@^1.1.3",
    "@std/tar": "jsr:@std/tar@^0.1.9",
    "@std/testing": "jsr:@std/testing@^1.0.16",
    "cookie": "npm:cookie@^1.0.2",
    "@sendgrid/helpers": "npm:@sendgrid/helpers@^8.0.0",
    "hono/client": "npm:hono@^4.10.4/client",
    "jose": "npm:jose@^6.1.3",
    "nanoid": "npm:nanoid@^5.1.6",
    "openapi-fetch": "npm:openapi-fetch@^0.15.0",
    "cron-parser": "npm:cron-parser@^5.5.0",
    "evalite/ai-sdk": "npm:evalite@^1.0.0-beta.15/ai-sdk",
    "@atlas/workspace-builder": "./packages/workspace-builder/mod.ts",
    "@atlas/fsm-engine": "./packages/fsm-engine/mod.ts",
    "@atlas/hallucination": "./packages/hallucination/mod.ts"
  },
  "allowScripts": [
    "npm:@sentry/cli@2.58.4",
    "npm:better-sqlite3@12.6.2",
    "npm:esbuild@0.27.1",
    "npm:esbuild@0.27.2",
    "npm:fsevents@2.3.3",
    "npm:protobufjs@7.5.4",
    "npm:protobufjs@8.0.0"
  ]
}
