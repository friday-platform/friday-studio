{
  "$schema": "https://raw.githubusercontent.com/denoland/deno/main/cli/schemas/config-file.v1.json",
  "version": "1.0.0",
  "workspace": ["./apps/*", "./packages/*", "./tools/memory_manager"],
  "compilerOptions": {
    "lib": ["deno.window", "deno.worker", "deno.unstable", "dom", "dom.iterable"],
    "types": [],
    "noImplicitAny": true,
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "jsx": "react-jsx",
    "jsxImportSource": "react"
  },
  "exclude": ["!integration-tests/**/*.test.ts", "apps/web-client/.svelte-kit", "tools/evals"],
  "unstable": ["broadcast-channel", "worker-options", "otel", "kv", "raw-imports"],
  "nodeModulesDir": "auto",
  "tasks": {
    "prepare": "deno run -A  npm:husky@^9",
    "lint-staged": "deno run -A npm:lint-staged@^16.1.2",
    "atlas": "cd \"$INIT_CWD\" && OTEL_DENO=true OTEL_SERVICE_NAME=atlas OTEL_SERVICE_VERSION=1.0.0 OTEL_RESOURCE_ATTRIBUTES=service.name=atlas,service.version=1.0.0 deno run -q --allow-all --unstable-broadcast-channel --unstable-worker-options --unstable-otel --unstable-kv --unstable-raw-imports --env-file \"$(git rev-parse --show-toplevel)/src/cli.tsx\"",
    "atlas-no-otel": "cd \"$INIT_CWD\" && deno run --allow-all --unstable-broadcast-channel --unstable-worker-options --unstable-kv --unstable-raw-imports --env-file \"$(git rev-parse --show-toplevel)/src/cli.tsx\"",
    "start": "OTEL_DENO=true deno run --allow-all --unstable-raw-imports src/cli.tsx",
    "test": "OTEL_DENO=true deno test --allow-all --unstable-raw-imports --no-check --env-file",
    "test:unit": "OTEL_DENO=true deno test --allow-all --env-file --no-check --ignore='integration-tests/**/*.test.ts' --ignore='packages/mcp/tests/manager.test.ts'",
    "test:integration": "OTEL_DENO=true ATLAS_USE_LLM_MOCKS=true deno test --allow-all --env-file --no-check 'integration-tests/**/*.test.ts' 'packages/mcp/tests/manager.test.ts'",
    "fmt": "deno run -A npm:@biomejs/biome format --write",
    "biome": "deno run -A npm:@biomejs/biome check --write",
    "lint": "deno lint",
    "example-acp-server": "deno run --allow-net --allow-env examples/workspaces/remote-agents/server.ts",
    "example-playwright-mcp-server": "deno run --allow-all --unstable-broadcast-channel --unstable-worker-options examples/workspaces/playwright-mcp/server.ts",
    "mock-mcp-weather": "deno run --allow-all integration-tests/mocks/weather-mcp-server.ts",
    "mock-mcp-file-tools": "deno run --allow-all integration-tests/mocks/file-tools-mcp-server.ts",
    "mock-mcp-echo": "deno run --allow-all integration-tests/mocks/echo-mcp-server.ts",
    "clean": "deno run --allow-read --allow-write --allow-env scripts/clean.ts",
    "validate-imports": "deno run --allow-read --allow-write scripts/validate-imports.ts",
    "validate-imports-staged": "deno run --allow-read --allow-write --allow-run scripts/validate-imports-staged.ts"
  },
  "imports": {
    "@ai-sdk/provider": "npm:@ai-sdk/provider@^2.0.0",
    "@biomejs/biome": "npm:@biomejs/biome@^2.2.2",
    "@hono/mcp": "npm:@hono/mcp@^0.1.0",
    "@hono/standard-validator": "npm:@hono/standard-validator@^0.1.4",
    "@modelcontextprotocol/sdk": "npm:@modelcontextprotocol/sdk@^1.15.0",
    "@opentelemetry/api": "npm:@opentelemetry/api@^1.9.0",
    "@scalar/hono-api-reference": "npm:@scalar/hono-api-reference@^0.9.9",
    "@std/assert": "jsr:@std/assert@^1.0.13",
    "@std/expect": "jsr:@std/expect@^1.0.16",
    "@std/tar": "jsr:@std/tar@^0.1.7",
    "@std/testing": "jsr:@std/testing@^1.0.12",
    "@std/fs": "jsr:@std/fs@^1.0.19",
    "@std/path": "jsr:@std/path@^1.1.1",
    "@std/async": "jsr:@std/async@^1.0.14",
    "@std/dotenv": "jsr:@std/dotenv@^0.225.0",
    "@std/yaml": "jsr:@std/yaml@^1.0.7",
    "@tanstack/svelte-query": "npm:@tanstack/svelte-query@^5.83.1",
    "ansi-escapes": "npm:ansi-escapes@^7.0.0",
    "chalk": "npm:chalk@^5.4.1",
    "eventsource-client": "npm:eventsource-client@^1.1.4",
    "fullscreen-ink": "npm:fullscreen-ink@^0.1.0",
    "ink": "npm:ink@^6.0.1",
    "js-levenshtein": "npm:js-levenshtein@^1.1.6",
    "lint-staged": "npm:lint-staged@^16.1.2",
    "marked": "npm:marked@^16.0.0",
    "marked-terminal": "npm:marked-terminal@^7.3.0",
    "openapi-fetch": "npm:openapi-fetch@^0.14.0",
    "playwright": "npm:playwright@^1.54.2",
    "react": "npm:react@^19.1.0",
    "@types/react": "npm:@types/react@^19.1.8",
    "ai": "npm:ai@^5.0.17",
    "@ai-sdk/anthropic": "npm:@ai-sdk/anthropic@^2.0.5",
    "@ai-sdk/openai": "npm:@ai-sdk/openai@^2.0.16",
    "@ai-sdk/google": "npm:@ai-sdk/google@^2.0.7",
    "xstate": "npm:xstate@^5.20.1",
    "zod": "npm:zod@^3.25.74",
    "@inkjs/ui": "npm:@inkjs/ui@^2.0.0",
    "hono": "npm:hono@^4.8.5",
    "hono/cors": "npm:hono@^4.8.5/cors",
    "hono/logger": "npm:hono@^4.8.5/logger",
    "hono/pretty-json": "npm:hono@^4.8.5/pretty-json",
    "hono/http-exception": "npm:hono@^4.8.5/http-exception",
    "hono/streaming": "npm:hono@^4.8.5/streaming",
    "hono-openapi": "npm:hono-openapi@^0.5.0-rc.2",
    "zod-openapi": "npm:zod-openapi@^5.2.0",
    "cron-parser": "npm:cron-parser@^5.3.0",
    "yargs": "https://deno.land/x/yargs@v18.0.0-deno/deno.ts"
  },
  "lint": { "rules": { "tags": ["recommended"], "exclude": ["apps/web-client/.vite/**/*"] } }
}
