{
  "$schema": "https://raw.githubusercontent.com/denoland/deno/main/cli/schemas/config-file.v1.json",
  "version": "1.0.0",
  "workspace": [
    "./apps/*",
    "./packages/*",
    "./tools/memory_manager",
    "./tools/evals",
    "./tools/evals-2"
  ],
  "compilerOptions": {
    "lib": ["deno.window", "deno.worker", "deno.unstable", "dom", "dom.iterable"],
    "types": ["./reset.d.ts"],
    "noImplicitAny": true,
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "jsx": "react-jsx",
    "jsxImportSource": "react"
  },
  "exclude": [
    "!integration-tests/**/*.test.ts",
    "apps/web-client/.svelte-kit",
    "apps/web-client/vite.config.ts",
    "apps/atlas-auth-ui/.svelte-kit",
    "apps/atlas-auth-ui/build",
    "apps/atlas-auth-ui/src/**",
    "apps/atlas-installer",
    "packages/vendor/**",
    "apps/web-client/src-tauri/**"
  ],
  "unstable": ["broadcast-channel", "worker-options", "otel", "kv", "raw-imports"],
  "nodeModulesDir": "auto",
  "tasks": {
    "prepare": "deno run -A  npm:husky@^9",
    "lint-staged": "deno run -A npm:lint-staged@^16.2.6",
    "atlas": "cd \"$INIT_CWD\" && deno run -q --allow-all --unstable-broadcast-channel --unstable-worker-options --unstable-kv --unstable-raw-imports --env-file \"$(git rev-parse --show-toplevel)/src/cli.tsx\"",
    "start": "deno run --allow-all --unstable-raw-imports src/cli.tsx",
    "test": "OTEL_DENO=true DENO_TESTING=true deno test --allow-all --unstable-raw-imports --no-check --env-file",
    "test:unit": "OTEL_DENO=true DENO_TESTING=true deno test --allow-all --env-file --no-check --ignore='integration-tests/**/*.test.ts'",
    "test:integration": "OTEL_DENO=true ATLAS_USE_LLM_MOCKS=true DENO_TESTING=true deno test --allow-all --env-file --no-check 'integration-tests/**/*.test.ts'",
    "fmt": "deno run -A npm:@biomejs/biome format --write",
    "fmt:check": "deno run -A npm:@biomejs/biome format",
    "biome": "deno run -A npm:@biomejs/biome check",
    "lint": "deno lint",
    "example-acp-server": "deno run --allow-net --allow-env examples/workspaces/remote-agents/server.ts",
    "example-playwright-mcp-server": "deno run --allow-all --unstable-broadcast-channel --unstable-worker-options examples/workspaces/playwright-mcp/server.ts",
    "mock-mcp-weather": "deno run --allow-all integration-tests/mocks/weather-mcp-server.ts",
    "mock-mcp-file-tools": "deno run --allow-all integration-tests/mocks/file-tools-mcp-server.ts",
    "mock-mcp-echo": "deno run --allow-all integration-tests/mocks/echo-mcp-server.ts",
    "clean": "deno run --allow-read --allow-write --allow-env scripts/clean.ts",
    "compile": "./scripts/compile.sh",

    "report:knip": "npx knip --reporter markdown --max-issues 0 > reports/knip-report.md"
  },
  "lint": { "rules": { "tags": ["recommended"] }, "exclude": ["packages/vendor/**"] },
  "imports": {
    "@std/dotenv": "jsr:@std/dotenv@^0.225.5",
    "@std/fs": "jsr:@std/fs@^1.0.20",
    "@std/media-types": "jsr:@std/media-types@^1.1.0",
    "@std/path": "jsr:@std/path@^1.1.3",
    "@std/tar": "jsr:@std/tar@^0.1.9",
    "cookie": "npm:cookie@^1.0.2",
    "@sendgrid/helpers": "npm:@sendgrid/helpers@^8.0.0",
    "hono/client": "npm:hono@^4.10.4/client",
    "jose": "npm:jose@^6.1.3",
    "openapi-fetch": "npm:openapi-fetch@^0.15.0"
  }
}
