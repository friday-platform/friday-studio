{
  "$schema": "https://raw.githubusercontent.com/denoland/deno/main/cli/schemas/config-file.v1.json",
  "version": "1.0.0",
  "exports": "./mod.ts",
  "compilerOptions": {
    "lib": ["deno.window", "deno.worker", "deno.unstable"]
  },
  "unstable": ["broadcast-channel", "worker-options", "otel"],
  "tasks": {
    "atlas": "cd \"$INIT_CWD\" && OTEL_DENO=false OTEL_SERVICE_NAME=atlas OTEL_SERVICE_VERSION=1.0.0 OTEL_RESOURCE_ATTRIBUTES=service.name=atlas,service.version=1.0.0 deno run --allow-all --unstable-broadcast-channel --unstable-worker-options --unstable-otel --env-file \"$(git rev-parse --show-toplevel)/src/cli.tsx\"",
    "dev": "OTEL_DENO=true deno run --allow-all --watch src/cli.tsx",
    "start": "OTEL_DENO=true deno run --allow-all src/cli.tsx",
    "test": "OTEL_DENO=true deno test --allow-all",
    "fmt": "deno fmt",
    "lint": "deno lint"
  },
  "imports": {
    "@std/assert": "jsr:@std/assert@^1.0.13",
    "@std/fs": "jsr:@std/fs@^1.0.0",
    "@std/path": "jsr:@std/path@^1.0.0",
    "@std/async": "jsr:@std/async@^1.0.0",
    "@std/dotenv": "jsr:@std/dotenv@^0.225.0",
    "fullscreen-ink": "npm:fullscreen-ink@^0.0.2",
    "ink": "npm:ink@^5.0.1",
    "react": "npm:react@^18.3.1",
    "meow": "npm:meow@^13.2.0",
    "ai": "npm:ai@^4.0.7",
    "@ai-sdk/anthropic": "npm:@ai-sdk/anthropic@^1.0.2",
    "xstate": "npm:xstate@^5.18.0"
  },
  "fmt": {
    "lineWidth": 100
  },
  "lint": {
    "rules": {
      "tags": ["recommended"]
    }
  }
}
