{
  "$schema": "https://raw.githubusercontent.com/denoland/deno/main/cli/schemas/config-file.v1.json",
  "version": "1.0.0",
  "workspace": [
    "./apps/*",
    "./packages/*",
    "./tools/memory_manager",
    "./tools/evals",
    "./tools/evals-2"
  ],
  "compilerOptions": {
    "lib": ["deno.window", "deno.worker", "deno.unstable", "dom", "dom.iterable"],
    "types": ["./reset.d.ts"],
    "noImplicitAny": true,
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "jsx": "react-jsx",
    "jsxImportSource": "react"
  },
  "exclude": [
    "!integration-tests/**/*.test.ts",
    "apps/web-client/.svelte-kit",
    "apps/web-client/vite.config.ts",
    "apps/atlas-auth-ui/.svelte-kit",
    "apps/atlas-auth-ui/build",
    "apps/atlas-auth-ui/src/**",
    "apps/atlas-installer",
    "packages/vendor/**",
    "apps/web-client/src-tauri/**"
  ],
  "unstable": ["broadcast-channel", "worker-options", "otel", "kv", "raw-imports"],
  "nodeModulesDir": "auto",
  "tasks": {
    "prepare": "deno run -A  npm:husky@^9",
    "lint-staged": "deno run -A npm:lint-staged@^16.2.6",
    "atlas": "deno run -q --allow-all --unstable-broadcast-channel --unstable-worker-options --unstable-kv --unstable-raw-imports --env-file --watch src/cli.tsx",
    "start": "deno run --allow-all --unstable-raw-imports src/cli.tsx",
    "dev": "deno run -A npm:concurrently -n daemon,link -c blue,green 'deno task atlas daemon start' 'cd apps/link && deno task dev'",
    "test": "OTEL_DENO=true DENO_TESTING=true LINK_DEV_MODE=true deno test --allow-all --unstable-raw-imports --no-check --env-file",
    "test:unit": "OTEL_DENO=true DENO_TESTING=true LINK_DEV_MODE=true deno test --allow-all --env-file --no-check --ignore='integration-tests/**/*.test.ts'",
    "fmt": "deno run -A npm:@biomejs/biome format --write",
    "fmt:check": "deno run -A npm:@biomejs/biome format",
    "biome": "deno run -A npm:@biomejs/biome",
    "lint": "deno lint --fix && deno run -A npm:@biomejs/biome check --write",
    "lint:check": "deno lint && deno run -A npm:@biomejs/biome check",
    "clean": "deno run --allow-read --allow-write --allow-env scripts/clean.ts",
    "compile": "./scripts/compile.sh"
  },
  "lint": {
    "rules": { "tags": ["recommended"] },
    "exclude": ["packages/vendor/**", "apps/atlas-auth-ui/vite.config.ts"]
  },
  "imports": {
    "@std/assert": "jsr:@std/assert@^1.0.16",
    "@std/async": "jsr:@std/async@^1.0.15",
    "@std/dotenv": "jsr:@std/dotenv@^0.225.5",
    "@std/fs": "jsr:@std/fs@^1.0.20",
    "@std/media-types": "jsr:@std/media-types@^1.1.0",
    "@std/path": "jsr:@std/path@^1.1.3",
    "@std/tar": "jsr:@std/tar@^0.1.9",
    "@std/testing": "jsr:@std/testing@^1.0.16",
    "cookie": "npm:cookie@^1.0.2",
    "@sendgrid/helpers": "npm:@sendgrid/helpers@^8.0.0",
    "hono/client": "npm:hono@^4.10.4/client",
    "jose": "npm:jose@^6.1.3",
    "nanoid": "npm:nanoid@^5.1.6",
    "openapi-fetch": "npm:openapi-fetch@^0.15.0",
    "@atlas/workspace-builder": "./packages/workspace-builder/mod.ts",
    "@atlas/fsm-engine": "./packages/fsm-engine/mod.ts"
  },
  "allowScripts": [
    "npm:@sentry/cli@2.58.4",
    "npm:esbuild@0.27.1",
    "npm:fsevents@2.3.3",
    "npm:protobufjs@7.5.4"
  ]
}
