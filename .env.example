# Friday Studio environment variables
#
# Copy this file to `.env` and fill in the keys you need. Anything you
# don't set will fall back to runtime defaults (or be disabled). The
# daemon loads `.env` automatically when started via `deno task atlas`.

# ──────────────────────────────────────────────────────────────────────
# LLM provider keys
# ──────────────────────────────────────────────────────────────────────
# At least one provider key is required for real agent runs. The
# bundled examples use Anthropic by default.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=

# ──────────────────────────────────────────────────────────────────────
# Tool / integration credentials
# ──────────────────────────────────────────────────────────────────────
# GitHub personal access token — required by the claude-code agent and
# the `pr-review-github` example.
GH_TOKEN=

# Optional: web search tool used by some example workspaces.
TAVILY_API_KEY=

# ──────────────────────────────────────────────────────────────────────
# Daemon configuration (all optional)
# ──────────────────────────────────────────────────────────────────────
# Where the daemon stores its state (sqlite db, artifacts, sessions).
# Defaults to ~/.atlas
# ATLAS_HOME=

# Log level: debug | info | warn | error
ATLAS_LOG_LEVEL=info

# Daemon HTTP API URL (used by the CLI to talk to the daemon).
# ATLAS_URL=http://localhost:8080

# Show the internal "kernel" workspace in the picker. Off by default.
# ATLAS_EXPOSE_KERNEL=0

# ──────────────────────────────────────────────────────────────────────
# Production-only (leave unset for local dev)
# ──────────────────────────────────────────────────────────────────────
# Postgres connection used by the `link` credential service in
# production. Local dev uses sqlite — leave this empty.
# POSTGRES_CONNECTION=
