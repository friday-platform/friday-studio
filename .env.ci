# CI Environment Variables for Testing
# This file provides minimal environment variables needed for tests to run in CI
# WITHOUT providing real API keys (tests will use mocks instead)

# Force LLM mocks usage in CI
ATLAS_USE_LLM_MOCKS=true

# Basic environment setup
NODE_ENV=test
ATLAS_LOG_LEVEL=error

# Minimal required variables for tests to run (dummy values)
ANTHROPIC_API_KEY=dummy-key-for-ci
LINEAR_API_KEY=dummy-linear-key
LINEAR_TEAM_ID=TEST
LINEAR_WEBHOOK_SECRET=dummy-webhook-secret
TAVILY_API_KEY=dummy-tavily-key
GITHUB_PERSONAL_ACCESS_TOKEN=dummy-github-token

# This file is used by GitHub Actions CI to provide environment variables
# for testing without exposing real API keys. The ATLAS_USE_LLM_MOCKS=true
# setting ensures that LLM provider tests use mocks instead of real API calls.