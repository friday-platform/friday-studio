  audit-orphans:
    description: >-
      Run the orphan-agent-auditor and emit the list of unwired user agents. The cross-artifact
      integration check.
    title: Audit orphan agents
    triggers:
      - signal: audit-orphans
    fsm:
      id: audit-orphans-pipeline
      initial: idle
      states:
        idle:
          'on':
            audit-orphans:
              target: step_audit
        step_audit:
          entry:
            - type: code
              function: prepare_audit
            - type: agent
              agentId: orphan-auditor
              outputTo: audit-output
              outputType: orphan-audit-result
            - type: emit
              event: ADVANCE
          'on':
            ADVANCE:
              target: completed
              guards:
                - guard_audit_done
        completed:
          type: final
      functions:
        prepare_audit:
          type: action
          code: |
            export default function prepare_audit(context, event) {
              // Exclude bundled atlas agents (they're globally available
              // and don't need FSM consumers) and library-style user agents
              // (called by other agents, not by FSMs directly).
              return {
                task: 'Audit orphan agents across all workspaces',
                config: {
                  platformUrl: 'http://localhost:8080',
                  // Restrict to known user-built agents so we don't flag
                  // bundled atlas agents (claude-code, slack, etc.) as orphans.
                  user_agent_ids: [
                    'autopilot-dispatcher',
                    'autopilot-planner',
                    'multi-session-reflector',
                    'orphan-agent-auditor',
                    'reflection-aggregator',
                    'reflector',
                    'session-summarizer',
                    'skill-author',
                    'skill-publisher',
                    'task-router',
                    'workspace-creator'
                  ],
                  // Library agents are called from inside other agents,
                  // not directly from FSMs. orphan-agent-auditor v1.2+
                  // honors this field and excludes them from the orphan
                  // count (still surfaced under library_orphans_excluded
                  // in the result for transparency).
                  library_agents: [
                    'session-summarizer',
                    'reflection-aggregator'
                  ]
                },
              };
            }
        guard_audit_done:
          type: guard
          code: |
            export default function guard_audit_done(context, event) {
              return context.results['audit-output'] !== undefined;
            }
      documentTypes:
        orphan-audit-result:
          type: object
          properties:
            total_user_agents:
              type: integer
            referenced_count:
              type: integer
            orphan_count:
              type: integer
            orphans:
              type: array
              items:
                type: object
                properties:
                  agent_id:
                    type: string
                  version:
                    type: string
                required:
                  - agent_id
            referenced:
              type: array
              items:
                type: object
                properties:
                  agent_id:
                    type: string
                  workspaces:
                    type: array
                    items:
                      type: string
                required:
                  - agent_id
            rationale:
              type: string
          required:
            - total_user_agents
            - referenced_count
            - orphan_count
            - orphans
            - rationale
      tools: {}
  cross-session-reflect:
    description: >-
      Run multi-session-reflector against a target workspace to surface recurring failure patterns.
      v2 chains into skill-author + skill-publisher behind a confidence gate (>= 0.9).
    title: Cross-session reflect
    triggers:
      - signal: cross-session-reflect
    fsm:
      id: cross-session-reflect-pipeline
      initial: idle
      states:
        idle:
          'on':
            cross-session-reflect:
              target: step_reflect
        step_reflect:
          entry:
            - type: code
              function: prepare_reflect
            - type: agent
              agentId: cross-session-reflector
              outputTo: reflect-output
              outputType: cross-session-reflect-result
            - type: emit
              event: ADVANCE
          'on':
            ADVANCE:
              - target: step_author
                guards:
                  - guard_reflect_done
                  - guard_skill_warranted
              - target: completed
                guards:
                  - guard_reflect_done
        step_author:
          entry:
            - type: code
              function: prepare_author
            - type: agent
              agentId: skill-author
              outputTo: author-output
              outputType: skill-author-result
            - type: emit
              event: AUTHOR_DONE
          'on':
            AUTHOR_DONE:
              - target: step_publish
                guards:
                  - guard_author_done
                  - guard_publish_ready
              - target: completed
                guards:
                  - guard_author_done
        step_publish:
          entry:
            - type: code
              function: prepare_publish
            - type: agent
              agentId: skill-publisher
              outputTo: publish-output
              outputType: skill-publisher-result
            - type: emit
              event: PUBLISH_DONE
          'on':
            PUBLISH_DONE:
              target: completed
        completed:
          type: final
      functions:
        prepare_reflect:
          type: action
          code: |
            export default function prepare_reflect(context, event) {
              var wsId = (event.data && event.data.workspace_id) || 'grilled_xylem';
              var n = (event.data && event.data.n) || 10;
              return {
                task: 'Cross-session reflect on ' + wsId,
                config: {
                  workspace_id: wsId,
                  n: n,
                  platformUrl: 'http://localhost:8080',
                },
              };
            }
        guard_reflect_done:
          type: guard
          code: |
            export default function guard_reflect_done(context, event) {
              return context.results['reflect-output'] !== undefined;
            }
        guard_skill_warranted:
          type: guard
          code: |
            export default function guard_skill_warranted(context, event) {
              var reflect = context.results['reflect-output'];
              if (!reflect || !reflect.judgment) return false;
              return reflect.judgment.skill_update_warranted === true &&
                     reflect.judgment.confidence >= 0.9;
            }
        prepare_author:
          type: action
          code: |
            export default function prepare_author(context, event) {
              var reflect = context.results['reflect-output'];
              if (!reflect) throw new Error('Reflect output not found');
              return {
                task: 'Author skill update based on cross-session judgment',
                config: {
                  judgment: reflect.judgment,
                  current_skill_md: '',
                  platformUrl: 'http://localhost:8080',
                },
              };
            }
        guard_author_done:
          type: guard
          code: |
            export default function guard_author_done(context, event) {
              return context.results['author-output'] !== undefined;
            }
        guard_publish_ready:
          type: guard
          code: |
            export default function guard_publish_ready(context, event) {
              var author = context.results['author-output'];
              return author != null && author.proposed_skill_md != null;
            }
        prepare_publish:
          type: action
          code: |
            export default function prepare_publish(context, event) {
              var author = context.results['author-output'];
              if (!author) throw new Error('Author output not found');
              return {
                task: 'Publish proposed skill update',
                config: {
                  proposed_skill_md: author.proposed_skill_md,
                  platformUrl: 'http://localhost:8080',
                },
              };
            }
      documentTypes:
        cross-session-reflect-result:
          type: object
          properties:
            workspace_id:
              type: string
            n_sessions_scanned:
              type: integer
            judgment:
              type: object
              properties:
                matches_known_pattern:
                  type: boolean
                skill_update_warranted:
                  type: boolean
                confidence:
                  type: number
                rationale:
                  type: string
            summary:
              type: string
          required:
            - workspace_id
            - judgment
        skill-author-result:
          type: object
          properties:
            proposed_skill_md:
              anyOf:
                - type: string
                - type: 'null'
            rationale:
              anyOf:
                - type: string
                - type: 'null'
          required: []
        skill-publisher-result:
          type: object
          properties:
            published:
              type: boolean
            skill_name:
              anyOf:
                - type: string
                - type: 'null'
            version:
              anyOf:
                - type: string
                - type: 'null'
            rationale:
              anyOf:
                - type: string
                - type: 'null'
          required:
            - published
      tools: {}
agents:
  planner:
    description: >-
      Custom Python WASM agent. Reads the backlog, picks the next eligible task, returns a
      structured plan. No LLM. No HTTP mutation. Replaces the "what should I work on next" function
      that I (the operator) have been performing manually.
    type: user
    agent: autopilot-planner
    prompt: |
      You are the autopilot planner. Read your config, fetch the
      backlog, pick the next eligible task, and emit a structured
      action.

      Pure deterministic. NO LLM. Filter by status==pending, skip
      blocked tasks, sort by priority desc + created_at asc, take
      the first.

      Output action='execute' with target_workspace_id +
      target_signal_id + signal_payload, OR action='idle' if no
      eligible task exists.
    env:
      ANTHROPIC_API_KEY: from_environment
  orphan-auditor:
    description: >-
      Custom Python WASM agent. Audits the registry vs all loaded workspace configs, returns the
      list of user agents with no FSM consumer. The cross-artifact integration check that the
      single-session reflector cannot do. Closes the orphan-agent failure mode that produced 4+
      unwired agents tonight.
    type: user
    agent: orphan-agent-auditor
    prompt: |
      You are the orphan-agent auditor. List user agents from
      /api/agents, scan workspace.config.agents in every workspace
      via /api/workspaces and /api/workspaces/{id}, return the
      agents not referenced anywhere as orphans.
    env:
      ANTHROPIC_API_KEY: from_environment
  dispatcher:
    description: >-
      Custom Python WASM agent. Takes a planner plan-output and fires the target signal at the
      target workspace via HTTP POST. Blocks until the downstream FSM returns. Closes the autopilot
      loop — without this, planner output is inert metadata.
    type: user
    agent: autopilot-dispatcher
    prompt: |
      You are the autopilot dispatcher. Read your config, short-circuit
      on action=='idle', otherwise POST to
      /api/workspaces/{target_workspace_id}/signals/{target_signal_id}
      with the signal payload. Return dispatched=true with session_id
      on 2xx; dispatched=false on idle; err on 4xx/5xx.
    env:
      ANTHROPIC_API_KEY: from_environment
  cross-session-reflector:
    description: >-
      Custom Python WASM agent. Cross-session reflector — reads the last N completed sessions for a
      workspace, computes structural signals, asks claude-haiku for a single recurring-pattern
      judgment. Companion to the single-session reflector. Wired here so the agent isn't orphaned.
    type: user
    agent: multi-session-reflector
    prompt: |
      You are the cross-session reflector. Read your config
      (workspace_id, n) and emit a reflection-result-multi.
    env:
      ANTHROPIC_API_KEY: from_environment
  skill-author:
    description: >-
      Custom Python WASM agent. Takes a high-confidence reflection proposal + current SKILL.md and
      produces a complete replacement SKILL.md with a new failure-mode row added. Single LLM call,
      strict structured output, gated on confidence >= 0.9.
    type: user
    agent: skill-author
    env:
      ANTHROPIC_API_KEY: from_environment
  skill-publisher:
    description: >-
      Custom Python WASM agent. Pure mechanical multipart upload of a new SKILL.md to
      /api/skills/@tempest/{name}/upload. Records previous_version for rollback. No LLM call.
    type: user
    agent: skill-publisher
    env:
      ANTHROPIC_API_KEY: from_environment
