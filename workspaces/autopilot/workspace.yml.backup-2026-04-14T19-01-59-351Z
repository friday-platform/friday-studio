version: '1.0'
workspace:
  name: FAST Autopilot
  description: >-
    The control loop that's meant to replace the human (or Claude session) sitting in front of FAST
    as overwatch. v1 is a planner-only pipeline: a cron tick fires autopilot-planner, which reads a
    backlog and emits the next task to dispatch. v2 adds a dispatcher step that actually fires the
    chosen signal at the chosen workspace and polls until done. v3 adds a reflect step that runs
    reflector + multi-session-reflector after each completion. v4 adds skill-author +
    skill-publisher chained behind a confidence gate.
skills: []
signals:
  autopilot-tick:
    description: >-
      Manually fire one autopilot iteration via HTTP. The cron-driven counterpart is
      autopilot-tick-cron — both feed the same job.
    title: Autopilot tick
    schema:
      type: object
      properties:
        backlog_url:
          type: string
          description: >-
            Optional override for the backlog source URL. Defaults to the atlas-mounted backlog
            file.
        max_iterations:
          type: integer
          description: v1 ignores this. Reserved for v2 batch-dispatch.
    provider: http
    config:
      path: /webhooks/autopilot-tick
  autopilot-tick-cron:
    description: >-
      Cron-driven autopilot iteration. Currently ~5 min cadence — was every minute but that just
      spun the same task repeatedly because the planner doesn't know what's already in flight. Once
      the planner gains "skip-recent" logic and the backlog is stateful, this can tighten back to 1
      min. Treadmill prevention > visible cadence.
    title: Autopilot tick (scheduled)
    provider: schedule
    config:
      schedule: '*/5 * * * *'
      timezone: UTC
  audit-orphans:
    description: >-
      Run the orphan-agent-auditor against the live registry and emit the list of user agents not
      wired into any FSM. Operator runs this to catch the structural failure mode where authoring
      runs ahead of integration.
    title: Audit orphan agents
    schema:
      type: object
      properties: {}
    provider: http
    config:
      path: /webhooks/audit-orphans
  cross-session-reflect:
    description: >-
      Run the multi-session-reflector against a target workspace's recent N completed sessions.
      Surfaces recurring failure patterns that a single-session reflector cannot see.
    title: Cross-session reflect
    schema:
      type: object
      properties:
        workspace_id:
          type: string
          description: Target workspace whose sessions to scan. Defaults to grilled_xylem.
        'n':
          type: integer
          description: How many recent completed sessions to scan. Default 10.
    provider: http
    config:
      path: /webhooks/cross-session-reflect
jobs:
  autopilot-tick:
    description: >-
      v1: call the planner, emit the chosen action as a structured output. The operator (or a future
      dispatcher) reads the output and acts on it. v2 will add a dispatch step.
    title: Autopilot iteration
    triggers:
      - signal: autopilot-tick
      - signal: autopilot-tick-cron
    fsm:
      id: autopilot-pipeline
      initial: idle
      states:
        idle:
          'on':
            autopilot-tick:
              target: step_plan
            autopilot-tick-cron:
              target: step_plan
        step_plan:
          entry:
            - type: code
              function: prepare_plan
            - type: agent
              agentId: planner
              outputTo: plan-output
              outputType: plan-result
            - type: emit
              event: ADVANCE
          'on':
            ADVANCE:
              target: completed
              guards:
                - guard_plan_done
