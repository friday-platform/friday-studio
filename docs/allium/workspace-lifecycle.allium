// =============================================================================
// Workspace Lifecycle -- Behavioral Specification
//
// Covers: workspace registration, config loading, runtime creation/destruction,
// session execution, idle timeout, config hot-reload, and daemon shutdown.
// =============================================================================

// ---------------------------------------------------------------------------
// Entities
// ---------------------------------------------------------------------------

entity Workspace {
  id:          String,
  name:        String,
  path:        String,           // filesystem path or "system://{id}"
  config_path: String,           // absolute path to workspace.yml or eph_workspace.yml
  status:      inactive | running | stopped,
  created_at:  Timestamp,
  last_seen:   Timestamp,
  system:      Boolean,          // embedded system workspace (immutable config)
  ephemeral:   Boolean,          // eph_workspace.yml with 30-day TTL
  error:       String | null,
  failure_count: Integer
}

entity WorkspaceRuntime {
  workspace_id:  String,
  initialized:   Boolean,
  jobs:          Map<String, FSMJob>,
  sessions:      Map<String, ActiveSession>,
  orchestrator:  AgentOrchestrator
}

entity FSMJob {
  name:           String,
  fsm_path:       String,       // empty for inline FSM definitions
  engine:         FSMEngine | null,  // lazily created
  document_store: DocumentStore | null,
  signals:        List<String>,
  fsm_definition: Object | null,    // inline definition from workspace.yml
  description:    String | null
}

entity ActiveSession {
  id:         String,
  job_name:   String,
  signal_id:  String,
  status:     active | completed | failed | skipped,
  started_at: Timestamp,
  completed_at: Timestamp | null,
  artifacts:  List<Artifact>,
  user_id:    String | null
}

value MergedConfig {
  atlas:     AtlasConfig | null,   // from atlas.yml (optional, platform-level)
  workspace: WorkspaceConfig       // from workspace.yml (required)
}

value WorkspaceConfig {
  version:       "1.0",
  workspace:     WorkspaceIdentity,
  server:        ServerConfig | null,
  tools:         ToolsConfig | null,
  signals:       Map<String, SignalConfig> | null,
  jobs:          Map<String, JobSpecification> | null,
  agents:        Map<String, AgentConfig> | null,
  notifications: NotificationConfig | null,
  federation:    FederationConfig | null
}

value AtlasConfig {
  // Superset of WorkspaceConfig with platform-level additions:
  supervisors:  SupervisorsConfig | null,
  planning:     PlanningConfig | null,
  runtime:      RuntimeConfig | null
}


// ---------------------------------------------------------------------------
// Config Loading
// ---------------------------------------------------------------------------

rule LoadWorkspaceConfig {
  when:     external ConfigLoader.load(workspace_path)
  requires: workspace_path contains "workspace.yml" OR "eph_workspace.yml"
  ensures:
    // workspace.yml takes precedence over eph_workspace.yml when both exist
    config.workspace is parsed and validated via WorkspaceConfigSchema,
    config.atlas is parsed and validated via AtlasConfigSchema if atlas.yml exists,
    config.atlas is null if atlas.yml does not exist,
    // MergedConfig keeps both configs separate (no deep merge)
    result is MergedConfig { atlas, workspace }
}

rule SystemWorkspaceConfigResolution {
  when:     external GetWorkspaceConfig(workspace_id) AND ws: Workspace.system == true
  requires: workspace_id exists in SYSTEM_WORKSPACES embedded map
  ensures:
    config is loaded from compiled-in SYSTEM_WORKSPACES[workspace_id],
    config.atlas is always null for system workspaces,
    filesystem is never accessed
}

rule ValidateSignalPayload {
  when:     external ValidateSignalPayload(signal_name, payload)
  requires: signal_name exists in workspace.signals OR atlas.signals
  ensures:  payload matches signal's declared schema
}

open_question "Config merging is not a deep merge -- MergedConfig keeps atlas and workspace as separate fields. The runtime only reads from config.workspace for jobs, signals, agents. When does atlas config actually influence behavior? Currently supervisors/planning/runtime from atlas.yml appear to be unused by WorkspaceRuntime."

open_question "AtlasConfig extends WorkspaceConfigSchema, meaning atlas.yml also has signals/jobs/agents. validateMergedConfig merges signals from both for system-signal validation, but WorkspaceRuntime only reads config.workspace.jobs and config.workspace.signals. Signals defined only in atlas.yml would be invisible to the runtime."


// ---------------------------------------------------------------------------
// Workspace Registration
// ---------------------------------------------------------------------------

rule RegisterWorkspace {
  when:     external RegisterWorkspace(path, options)
  requires:
    path points to a directory containing workspace.yml or eph_workspace.yml,
    config passes Zod validation,
    all MCP server "auto" env vars are available in system or workspace .env
  ensures:
    ws: Workspace.created with status == inactive,
    ws is persisted in registry,
    if NOT ephemeral: signals are registered with all signal registrars (cron, fs-watch),
    if NOT system: config file watcher is attached
}

rule RegisterSystemWorkspaces {
  when:     external WorkspaceManager.initialize()
  requires: SYSTEM_WORKSPACES map contains at least one entry
  ensures:
    for each system workspace: entry exists in registry (idempotent),
    system workspace signals are registered with registrars
}

rule AutoImportWorkspaces {
  when:     external WorkspaceManager.initialize() AND NOT test_mode
  ensures:
    directories under ~/.atlas/workspaces/ are scanned (depth 3),
    directories with workspace.yml or eph_workspace.yml are registered,
    expired ephemeral configs (>30 days) are removed and skipped,
    failures are logged and skipped (never block startup)
}


// ---------------------------------------------------------------------------
// Runtime Creation (On-Demand)
// ---------------------------------------------------------------------------

rule GetOrCreateWorkspaceRuntime {
  when:     external GetOrCreateRuntime(workspace_id)
  requires:
    daemon is initialized,
    workspace_id exists in registry
  ensures:
    if runtime already exists in daemon.runtimes: return existing,
    if inactive with prior error: clear error fields before creation,
    if max_concurrent_workspaces reached: evict oldest idle workspace OR throw,
    workspace path is validated (exists, is directory) unless system workspace,
    config is loaded via WorkspaceManager.getWorkspaceConfig,
    LLM agents from workspace config are registered in agent registry,
    Atlas agent wrappers from workspace config are registered in agent registry,
    Workspace domain object is created from config,
    WorkspaceRuntime is constructed with lazy=true and MCP server pool,
    runtime is stored in daemon.runtimes map,
    runtime is registered with WorkspaceManager (status -> running),
    idle timeout is set
}

rule RuntimeLazyInitialization {
  when:     rt: WorkspaceRuntime.processSignal() AND rt.initialized == false
  ensures:
    rt.initialize() is called,
    jobs from config.workspace.jobs are registered (inline FSM definitions),
    standalone FSM files (*.fsm.yaml) are discovered in workspace directory,
    rt.initialized becomes true
}

rule JobEngineLazyInitialization {
  when:     job: FSMJob.engine == null AND signal matches job
  ensures:
    document store is created for the job,
    MCP tool provider is created (even if no MCP servers configured -- for ambient tools),
    FSM engine is created from inline definition or file,
    engine is initialized
}


// ---------------------------------------------------------------------------
// Signal Processing and Session Lifecycle
// ---------------------------------------------------------------------------

rule ProcessSignal {
  when:     external ProcessSignal(signal)
  requires:
    runtime is initialized,
    at least one job's signals list contains signal.id
  ensures:
    first matching job is selected (TODO: multi-job support),
    job engine is lazily initialized if needed,
    session is created and tracked
}

rule TriggerSignalFreshExecution {
  when:     signal.id is a trigger signal (listed in job.triggers)
  ensures:
    persisted state files are cleared,
    FSM engine is reset to initial state,
    session starts from scratch
}

rule ContinuationSignal {
  when:     signal.id is NOT a trigger signal
  ensures:
    FSM state is preserved from prior execution,
    session resumes from current state
}

rule DirectJobExecution {
  when:     external ExecuteJobDirectly(job_name, params)
  requires: job_name exists in runtime.jobs
  ensures:
    job engine is lazily initialized,
    synthetic signal "job:{job_name}" is created,
    persisted state is always cleared (fresh execution),
    session is created and tracked
}

rule SessionCompletion {
  when:     session: ActiveSession.status becomes completed | failed | skipped
  ensures:
    session is persisted to SessionHistoryStorage,
    session title is generated asynchronously,
    FSM events are persisted chronologically,
    session-finish event is appended,
    onSessionFinished callback is invoked,
    analytics event is emitted (if userId present and status != skipped),
    session is removed from active tracking maps
}

rule SessionErrorClassification {
  when:     session execution throws error
  ensures:
    if error is UserConfigurationError: status becomes "skipped",
    otherwise: status becomes "failed"
}

open_question "WorkspaceRuntime.processSignal and executeJobDirectly have duplicate session-completion logic (persist, emit completion event, handle completion). The code is copy-pasted with minor differences -- executeJobDirectly does not pass onStreamEvent, and logs an extra message. This is a maintenance risk."


// ---------------------------------------------------------------------------
// Idle Timeout and Workspace Destruction
// ---------------------------------------------------------------------------

config {
  idle_timeout_ms:            Integer = 300000,   // 5 minutes
  max_concurrent_workspaces:  Integer = 10,
  session_timeout_ms:         Integer = 900000,   // 15 minutes (waitForCompletion)
  sse_heartbeat_interval_ms:  Integer = 30000,
  sse_connection_timeout_ms:  Integer = 300000
}

rule ResetIdleTimeout {
  when:     external signal is triggered for workspace OR runtime is created
  ensures:
    existing timeout is cleared,
    new timeout is scheduled for idle_timeout_ms
}

rule CheckAndDestroyIdleWorkspace {
  when:     idle timeout fires for workspace_id
  requires: workspace_id exists in daemon.runtimes
  ensures:
    if no active sessions AND no active agent executions: destroy runtime,
    if still active: reset idle timeout (keep alive)
}

rule DestroyWorkspaceRuntime {
  when:     external DestroyWorkspaceRuntime(workspace_id)
  ensures:
    runtime.shutdown() is called (stops FSM engines, shuts down orchestrator, clears jobs/sessions),
    runtime is removed from daemon.runtimes,
    runtime is unregistered from WorkspaceManager (status -> stopped),
    workspace status is set to "stopped" in registry,
    idle timeout is cleared
}

rule SessionFinishedRuntimeCleanup {
  when:     onSessionFinished callback fires
  ensures:
    workspace status is set to "stopped" in registry,
    if no remaining active sessions AND no active agent executions:
      runtime is destroyed immediately,
    else:
      idle timeout is reset
}

open_question "There is a status inconsistency: onSessionFinished always sets status to 'stopped', but then if sessions remain active, the idle timeout resets and the workspace keeps running. The registry status says 'stopped' while the runtime is still alive. Next getOrCreateWorkspaceRuntime call will find the existing runtime and return it, but a list() call via the manager will overlay 'running' status dynamically. The persisted status is misleading."


// ---------------------------------------------------------------------------
// Config Hot-Reload (File Watcher)
// ---------------------------------------------------------------------------

rule ConfigFileChanged {
  when:     file watcher detects modification to workspace.yml or eph_workspace.yml
  requires: file content hash differs from previous hash
  ensures:
    config YAML is validated against WorkspaceConfigSchema,
    if validation fails: change is silently skipped (logged),
    if validation passes: onConfigChange callback is invoked
}

rule HandleWorkspaceConfigChange {
  when:     ConfigFileChanged(workspace_id, file_path)
  ensures:
    if config file or directory is missing: workspace signals are unregistered and workspace is marked inactive with error,
    if config is invalid: workspace is marked inactive with error metadata,
    if config is valid: runtime is stopped, signals are restarted, workspace is marked inactive (ready for next signal)
}

rule AtomicSaveDetection {
  when:     file watcher receives rename event with single path (no new path)
  ensures:
    event is treated as file modification (not deletion),
    watchers remain active,
    config reload is triggered
}

rule ConfigRename {
  when:     file watcher detects rename with old_path and new_path
  ensures:
    watchers are stopped,
    new config is validated,
    if valid: registry paths are updated atomically, signals are restarted, watcher is reattached,
    if invalid: workspace entry is deleted
}


// ---------------------------------------------------------------------------
// Workspace Persistence Toggle
// ---------------------------------------------------------------------------

rule UpdateWorkspacePersistence {
  when:     external UpdatePersistence(workspace_id, make_persistent)
  requires: workspace exists in registry
  ensures:
    runtime is stopped if active,
    config file is renamed (workspace.yml <-> eph_workspace.yml),
    metadata.ephemeral is updated,
    if persistent: signals are registered with registrars,
    if ephemeral: signals are unregistered,
    watcher is reattached,
    status is set to inactive
}


// ---------------------------------------------------------------------------
// Workspace Deletion
// ---------------------------------------------------------------------------

rule DeleteWorkspace {
  when:     external DeleteWorkspace(workspace_id, options)
  requires:
    if system workspace: options.force must be true
  ensures:
    signals are unregistered from all registrars,
    runtime is shut down if active,
    workspace entry is removed from registry,
    file watcher is stopped,
    if options.remove_directory AND not system: directory is removed
}


// ---------------------------------------------------------------------------
// Daemon Shutdown
// ---------------------------------------------------------------------------

rule DaemonShutdown {
  when:     external Shutdown() OR SIGINT OR SIGTERM
  requires: daemon.is_shutting_down == false
  ensures:
    is_shutting_down flag is set (prevents re-entry),
    OS signal handlers are removed,
    all workspace runtimes are destroyed (parallel),
    StreamRegistry is shut down,
    all idle timeouts are cleared,
    SSE health check interval is stopped,
    agent session cleanup interval is stopped,
    platform session cleanup interval is stopped,
    all SSE client connections are closed,
    all agent MCP sessions are cleaned up,
    all platform MCP sessions are cleaned up,
    CronManager is shut down,
    Global MCP Server Pool is disposed,
    WorkspaceManager is closed (unregisters signals, stops runtimes, stops watcher, closes registry),
    LibraryStorage is closed,
    HTTP server is shut down,
    Analytics provider is flushed and shut down,
    Sentry events are flushed (2s timeout),
    30-second forced-exit timeout is active as safety net
}

rule WorkspaceRuntimeShutdown {
  when:     external WorkspaceRuntime.shutdown()
  ensures:
    all FSM engines are stopped,
    orchestrator is shut down,
    sessions map is cleared,
    jobs map is cleared,
    initialized flag is set to false
}

open_question "Daemon shutdown destroys all runtimes via destroyWorkspaceRuntime (which calls runtime.shutdown + unregisters from manager), but then also calls workspaceManager.close() which tries to shutdown all runtimes in its own map. The runtimes map in manager was already cleared by destroyWorkspaceRuntime. This is harmless but redundant."


// ---------------------------------------------------------------------------
// Concurrent Signal Guard
// ---------------------------------------------------------------------------

rule PreventConcurrentSignalExecution {
  when:     external TriggerWorkspaceSignal(workspace_id, signal_id)
  requires: runtime has no active sessions for this signal_id
  ensures:
    if active session exists for signal: throw error (prevents duplicate execution),
    otherwise: signal is processed normally
}


// ---------------------------------------------------------------------------
// Workspace Status State Machine
// ---------------------------------------------------------------------------

// Registry-persisted status transitions:
//
//   inactive --[getOrCreateRuntime]--> running
//   running  --[onSessionFinished]--> stopped
//   running  --[destroyRuntime]----> stopped
//   stopped  --[destroyRuntime]----> stopped (redundant but harmless)
//   running  --[configChange]------> inactive
//   *        --[signal error]------> inactive (with error metadata)
//
// Note: WorkspaceManager.find() dynamically overlays "running" when a runtime
// exists in memory, regardless of persisted status.

open_question "The status enum is {inactive, running, stopped}, but the transitions show 'stopped' as a transient state between sessions. There is no distinction between 'never started' (inactive) and 'was running, now idle' (stopped). After onSessionFinished sets status to 'stopped' and the runtime is destroyed, the next find() call returns the persisted 'stopped' status. But after a config change, status goes to 'inactive'. Both mean 'not running' with subtly different implications."


// ---------------------------------------------------------------------------
// Inconsistencies and Design Observations
// ---------------------------------------------------------------------------

open_question "WorkspaceRuntime session status uses {active, completed, failed, skipped} while IWorkspaceSession.status is typed as string with comment 'pending | running | completed | cancelled'. The daemon idle check uses WorkspaceSessionStatus {PENDING, EXECUTING, COMPLETED, CANCELLED} from @atlas/core. These three status enums are not aligned. The runtime never produces 'pending', 'executing', or 'cancelled' -- it produces 'active', 'completed', 'failed', 'skipped'. The idle check looks for EXECUTING and PENDING, which are never set by WorkspaceRuntime."

open_question "The Workspace domain class (src/core/workspace.ts) has methods for managing signals, agents, workflows, sources, and actions. But WorkspaceRuntime does not use the Workspace class for session management -- it has its own parallel tracking. Workspace.fromConfig is called during runtime creation in the daemon, but the resulting object is only used to pass an ID and members to WorkspaceRuntime. The Workspace class's add/remove methods and snapshot() are never called in the runtime path."

open_question "WorkspaceRuntime.toWorkspaceSession() creates a stub implementation of IWorkspaceSession with no-op methods (cancel, cleanup, start) and stub managers. The IWorkspaceSession interface was designed for a different execution model and is now vestigial. The only meaningful methods are waitForCompletion() and getArtifacts()."

open_question "Config hot-reload marks workspace as 'inactive' after successful reload, which means the runtime is destroyed. The next signal will trigger getOrCreateWorkspaceRuntime again. This is a full restart, not a live config update. There is no mechanism to update an existing runtime's config without destroying it."

open_question "The MCP environment validation (validateMCPEnvironmentForWorkspace) runs at registration time but not at runtime creation time. If an env var becomes unavailable between registration and runtime creation, the error surfaces as a runtime failure rather than a clear config validation error."
