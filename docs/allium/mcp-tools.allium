// MCP Tool Management System
// Covers: server lifecycle, tool discovery, credential resolution, pooling, platform server
//
// Two distinct MCP roles:
// 1. Protocol MCP (client) - agents consuming tools from external MCP servers
// 2. Platform MCP (server) - Atlas exposing its own capabilities via MCP protocol

// =============================================================================
// Core Entities
// =============================================================================

entity MCPServer {
  id: string,
  transport: Transport,
  auth: AuthConfig | null,
  tools_filter: ToolFilter | null,
  env: map<string, EnvValue>,
  timeout_ms: number = 30000,
  scope: platform | workspace | merged,
  connected: bool = false
}

entity Transport {
  type: stdio | http
}

variant StdioTransport : Transport {
  command: string,
  args: list<string>
}

variant HTTPTransport : Transport {
  url: string
}

value AuthConfig {
  type: bearer,
  token_env: string | null
}

value ToolFilter {
  allow: list<string> | null,
  deny: list<string> | null
}

// EnvValue is a discriminated union: plain string, auto-resolve, or Link credential ref
entity EnvValue {
  kind: literal | auto | link_ref
}

variant LiteralEnv : EnvValue {
  value: string
}

variant AutoEnv : EnvValue {
  // resolves from process.env[key] at runtime
}

variant LinkCredentialRef : EnvValue {
  id: string | null,
  provider: string | null,
  key: string
  // invariant: exactly one of id or provider must be set
}

// =============================================================================
// MCP Manager (Protocol MCP Client)
// =============================================================================
// Singleton that holds live MCP client connections.
// Wraps the Vercel AI SDK MCP client.

entity MCPManager {
  clients: map<string, MCPClientWrapper>,
  // note: MCPManager is a singleton (MCPManager.getInstance())
  // but GlobalMCPServerPool creates separate instances per config-key
}

value MCPClientWrapper {
  client: opaque,   // ai-sdk MCPClient
  config: MCPServer,
  connected: bool
}

// =============================================================================
// Server Registration
// =============================================================================

rule RegisterStdioServer {
  when: RegisterServer(config) where config.transport.type == stdio,
  requires:
    config.id is unique among manager.clients,
  ensures:
    command resolved (npx resolution via ATLAS_NPX_PATH then fallback paths),
    env values resolved (literals kept, "auto" read from process.env, link refs fetched),
    parent process env merged with resolved env,
    StdioMCPTransport created with resolved command + args + merged env,
    AI SDK MCP client created with transport,
    connection verified via tools() call with retry (up to 10 attempts, 500ms apart, 2s timeout each),
    client wrapper stored in manager.clients
}

rule RegisterHTTPServer {
  when: RegisterServer(config) where config.transport.type == http,
  requires:
    config.id is unique among manager.clients,
  ensures:
    env values resolved (same as stdio),
    auth headers built from resolved env (bearer token),
    StreamableHTTPClientTransport created with URL and auth headers,
    connection attempted with retry (3 attempts, exponential backoff 1-5s, 5s timeout),
    connection verified via tools() call with retry (3 attempts, exponential backoff),
    client wrapper stored in manager.clients
}

rule RegisterServerFailure {
  when: RegisterServer(config) fails,
  ensures:
    error classified:
      platform_connection_issue -> log at debug (transient),
      credential_not_found -> log at warn (user config issue),
      other -> log at error,
    error rethrown with transport context (command or url)
}

// =============================================================================
// Tool Discovery and Filtering
// =============================================================================

rule GetToolsForServers {
  when: GetTools(server_ids),
  ensures:
    for each server_id:
      if not in manager.clients -> warn and skip,
      if not connected -> attempt re-verification once,
      if still not connected -> warn and skip,
      fetch tools via client.tools(),
      apply tool filtering (allow list then deny list),
      convert MCP tool format to AI SDK format (parameters -> inputSchema),
    return merged tools from all servers
}

rule FilterTools {
  when: tools retrieved from server with filter config,
  ensures:
    if allow list set -> only tools in allow list pass,
    if deny list set -> tools in deny list excluded,
    allow checked first then deny (allow is whitelist, deny is blacklist),
    parameter-to-inputSchema conversion applied
}

// =============================================================================
// Credential Resolution
// =============================================================================
// Resolves env values before server registration.
// Three types: literal strings, "auto"/"from_environment", and Link credential refs.

rule ResolveLiteralEnv {
  when: env entry is a plain string (not "auto" or "from_environment"),
  ensures: value used as-is
}

rule ResolveAutoEnv {
  when: env entry value is "auto" or "from_environment",
  ensures:
    value read from process.env[key],
    if not found -> throw error
}

rule ResolveLinkCredentialById {
  when: env entry is LinkCredentialRef with id set,
  requires: ATLAS_KEY set in process.env (unless LINK_DEV_MODE=true),
  ensures:
    credential fetched from Link API via GET /link/internal/v1/credentials/:id,
    if 404 -> throw LinkCredentialNotFoundError,
    if expired_no_refresh -> throw error,
    if refresh_failed -> throw error,
    secret[key] extracted and returned as string
}

rule ResolveLinkCredentialByProvider {
  when: env entry is LinkCredentialRef with provider set (no id),
  requires: ATLAS_KEY set in process.env (unless LINK_DEV_MODE=true),
  ensures:
    credentials listed from Link API via GET /link/v1/summary?provider=X,
    first credential selected,
    credential fetched by resolved id (same as ResolveLinkCredentialById),
    secret[key] extracted and returned as string
}

rule LinkAuthHeaders {
  when: Link API call made,
  ensures:
    if LINK_DEV_MODE=true -> no auth headers,
    if LINK_DEV_MODE!=true -> Authorization: Bearer ATLAS_KEY required,
    if ATLAS_KEY missing in prod -> throw clear error
}

// =============================================================================
// MCPServerRegistry (Configuration Resolution)
// =============================================================================
// Static class that resolves hierarchical MCP server configuration.
// Separate from MCPManager -- this resolves *config*, MCPManager manages *connections*.

entity MCPServerRegistryState {
  server_configs: map<string, MCPServer>,
  initialized: bool = false,
  cached_platform_tools: list<string> | null
}

rule InitializeRegistry {
  when: Initialize(atlas_config, workspace_config),
  requires: not already initialized (idempotent, concurrent-safe via promise guard),
  ensures:
    platform tools fetched from daemon MCP endpoint with retry (3 attempts, exponential backoff),
    atlas-platform server injected into atlas_config with HTTP transport to daemon /mcp,
    if platform tools available -> tool allow-list set on atlas-platform,
    platform servers extracted from atlas_config.tools.mcp.servers (scope=platform),
    workspace servers extracted from workspace_config.tools.mcp.servers (scope=workspace),
    configs merged: workspace overrides platform for same server id,
    merged configs stored in registry
}

rule MergeServerConfig {
  when: same server id exists in both platform and workspace configs,
  ensures:
    transport: workspace wins,
    auth: workspace wins (falls back to platform if workspace has none),
    tools.allow: workspace wins (falls back to platform if workspace has none),
    tools.deny: platform deny + workspace deny concatenated (union),
    timeout_ms: workspace wins (falls back to platform),
    scope set to "merged"
}

// =============================================================================
// Global MCP Server Pool
// =============================================================================
// Connection pool that avoids spawning new processes per agent execution.
// Uses reference counting and automatic cleanup.

entity GlobalMCPServerPool {
  pooled_managers: map<config_key, PooledMCPManager>,
  cleanup_interval: duration = 5m
}

value PooledMCPManager {
  manager: MCPManager,
  server_configs: map<string, MCPServer>,
  ref_count: number,
  last_used: timestamp,
  cleanup_timer: timer | null
}

rule AcquireFromPool {
  when: GetMCPManager(server_configs_map),
  ensures:
    config_key generated from sorted server ids,
    if pool entry exists for config_key:
      ref_count incremented,
      last_used updated,
      cleanup_timer cancelled,
      existing manager returned,
    if no pool entry:
      new MCPManager created,
      each server registered (failures logged but don't block others),
      pool entry created with ref_count=1,
      manager returned
}

rule ReleaseToPool {
  when: ReleaseMCPManager(server_configs_map),
  ensures:
    ref_count decremented (min 0),
    last_used updated,
    if ref_count reaches 0 -> cleanup timer started (5 min delay)
}

rule PoolCleanup {
  when: cleanup timer fires for config_key,
  requires: ref_count <= 0,
  ensures:
    manager.dispose() called (closes all server connections),
    pool entry removed
}

rule PoolPeriodicCleanup {
  when: periodic interval (5 min),
  ensures:
    all entries with ref_count=0 and last_used > 5min ago cleaned up
}

rule PoolDispose {
  when: pool shutdown requested,
  ensures:
    all cleanup timers cancelled,
    all managers disposed (parallel, allSettled),
    pool cleared
}

// =============================================================================
// Agent Tool Fetching
// =============================================================================
// How tools flow from MCP servers to agent execution context.

rule BuildAgentContext {
  when: agent execution starting,
  ensures:
    workspace config fetched from daemon,
    workspace MCP servers merged with agent MCP servers (agent wins),
    atlas-platform server always injected (HTTP transport to daemon /mcp),
    pooled MCPManager acquired,
    tools fetched from all servers via getToolsForServers,
    pool reference released after fetch,
    tools attached to agent context
}

rule MergeAgentServers {
  when: building tool set for agent,
  ensures:
    precedence order: agent > platform > workspace,
    workspace servers loaded first,
    atlas-platform injected second,
    agent servers override everything
}

// =============================================================================
// FSM Engine Tool Provider
// =============================================================================
// Separate tool provider for FSM LLM actions with restricted platform tools.

rule FSMToolFiltering {
  when: FSM engine requests tools,
  ensures:
    atlas-platform always included,
    platform tools filtered through PLATFORM_TOOL_ALLOWLIST,
    only webfetch + artifact tools allowed from platform by default,
    external MCP server tools pass through unfiltered
}

config FSMPlatformToolAllowlist {
  allowed: list<string> = [webfetch, artifacts_create, artifacts_get, artifacts_update]
}

// =============================================================================
// Platform MCP Server (Atlas exposing capabilities)
// =============================================================================
// Atlas daemon runs an MCP server at /mcp that agents connect to.
// Exposes workspace, session, job, signal, library, fs, and system tools.

entity PlatformMCPServer {
  server: McpServer,
  daemon_url: string,
  capabilities: [prompts, tools, resources, logging, notifications]
}

rule PlatformServerInit {
  when: daemon starts,
  ensures:
    McpServer created with name="platform" version="1.0.0",
    all tools registered (workspace, session, job, signal, agent, library, fs, csv, artifact, system, fetch),
    all prompts registered (agent, job, library, session, signal, workspace, platform),
    resources registered (currently empty - superseded by skills system),
    cancellation notification handler setup
}

rule PlatformToolCategories {
  when: platform server initialized,
  ensures:
    workspace tools: list, delete, describe, persistence, convert_task_to_workspace,
    session tools: describe, cancel,
    job tools: list, describe,
    signal tools: list, trigger,
    agent tools: list, describe,
    library tools: list, get, get_stream, store, stats, templates,
    fs tools: glob, grep, ls, read, write,
    data tools: csv,
    artifact tools: create, update, get, get_by_chat,
    system tools: bash, version, webfetch
}

// =============================================================================
// MCP Server Discovery Registry (core/mcp-registry)
// =============================================================================
// Static + dynamic registry of known MCP server metadata.
// Used during workspace creation to match agent "needs" to servers.
// Different from MCPServerRegistry (which resolves config hierarchy).

entity MCPServerMetadata {
  id: string,
  name: string,
  domains: list<string>,
  url_domains: list<string> | null,
  description: string | null,
  constraints: string | null,
  security_rating: high | medium | low | unverified,
  source: agents | static | web,
  config_template: MCPServer,
  required_config: list<RequiredConfigField> | null
}

value RequiredConfigField {
  key: string,
  description: string,
  type: string | array | object | number,
  examples: list<string> | null
}

entity MCPDiscoveryRegistry {
  static_servers: map<string, MCPServerMetadata>,   // hardcoded in registry-consolidated.ts
  dynamic_storage: MCPRegistryStorageAdapter         // persisted (local KV or Cortex)
}

rule MatchNeedToServers {
  when: agent declares a "need" (capability requirement),
  ensures:
    need normalized (lowercase, trim, spaces/underscores to hyphens),
    static servers checked first,
    dynamic servers loaded from storage (graceful fallback to static-only on failure),
    static servers take precedence over dynamic with same id,
    matching logic (in priority order):
      1. exact match on domain,
      2. domain contains need (if need >= 3 chars),
      3. need contains domain (if domain >= 3 chars),
    all matching servers returned with matched domains
}

rule ValidateRequiredFields {
  when: MCP server matched to agent need,
  ensures:
    for each required config field:
      if Link credential ref -> resolve by provider via Link API,
      if plain env var -> check process.env,
    returns: missing_credentials + resolved_credentials
}

rule GenerateClarifications {
  when: matching produces ambiguity or missing config,
  ensures:
    bundled-missing-fields: matched agent but missing credentials,
    mcp-missing-fields: matched MCP server but missing credentials,
    bundled-ambiguous: multiple bundled agents match,
    mcp-ambiguous: multiple MCP servers match same need,
    no-match: need has no matching integration,
    clarifications grouped by agent name for reporting
}

// =============================================================================
// Storage Adapters for Dynamic Registry
// =============================================================================

entity MCPRegistryStorageAdapter {
  // interface: add, get, list, delete
}

variant LocalMCPRegistryAdapter : MCPRegistryStorageAdapter {
  // uses Deno.Kv with prefix ["mcp_registry"]
  // atomic check for add (no duplicates)
}

variant CortexMCPRegistryAdapter : MCPRegistryStorageAdapter {
  // uses Cortex blob storage with metadata filtering
  // metadata: entity_type=mcp_registry, registry_id, server_name, source
  // 10s timeout on all operations
}

rule SelectStorageAdapter {
  when: storage adapter needed,
  ensures:
    if CORTEX_URL set -> CortexMCPRegistryAdapter (requires ATLAS_KEY),
    otherwise -> LocalMCPRegistryAdapter (Deno.Kv at ~/.atlas/mcp-registry.db),
    adapter cached after first creation
}

// =============================================================================
// NPX Command Resolution (stdio transport)
// =============================================================================

rule ResolveNpxCommand {
  when: stdio transport with command="npx" or "npx.cmd",
  ensures:
    1. check ATLAS_NPX_PATH env var -> resolve symlinks -> validate file exists,
    2. if not found -> try fallback paths:
       macOS: /opt/homebrew/bin/npx, /usr/local/bin/npx, /usr/bin/npx, /home/linuxbrew/.linuxbrew/bin/npx
       Windows: C:\Program Files\nodejs\npx.cmd, %APPDATA%\npm\npx.cmd,
    3. if still not found -> fall back to system PATH with warning
}

// =============================================================================
// Connection Verification
// =============================================================================

rule VerifyStdioConnection {
  when: stdio MCP server registered,
  ensures:
    up to 10 retry attempts,
    500ms between retries,
    2s timeout per attempt,
    connection verified by calling client.tools(),
    returns connected=true on first success, false if all attempts fail
}

rule VerifyHTTPConnection {
  when: http MCP server registered,
  ensures:
    retry with exponential backoff (3 attempts, 1-5s),
    3s timeout per verification attempt,
    connection verified by calling client.tools(),
    returns connected=true on success, false on failure
}

// =============================================================================
// Server Lifecycle
// =============================================================================

rule CloseServer {
  when: CloseServer(server_id),
  ensures:
    client.close() called,
    200ms wait for process termination,
    connected set to false,
    errors logged at warn level (non-fatal)
}

rule DisposeManager {
  when: MCPManager.dispose(),
  ensures:
    all servers closed in parallel (allSettled),
    clients map cleared,
    300ms additional cleanup wait,
    telemetry recorded (success/failure counts)
}

// =============================================================================
// Open Questions
// =============================================================================

open_question "MCPServerRegistry (config hierarchy) and MCPDiscoveryRegistry (server metadata catalog) serve overlapping but distinct purposes. MCPServerRegistry resolves atlas.yml + workspace.yml configs at workspace boot. MCPDiscoveryRegistry matches agent 'needs' to known server templates during workspace creation. The naming is confusing -- both are called 'registry'. Should they be renamed to clarify their roles?"

open_question "MCPManager is used as both a singleton (MCPManager.getInstance()) and as instances created by GlobalMCPServerPool. The singleton pattern in MCPManager conflicts with pool-based lifecycle management. Which pattern should win?"

open_question "The atlas-platform server is injected in three separate places: (1) MCPServerRegistry.injectPlatformServer during registry init, (2) agent-context/index.ts mergeServerConfigs during agent context build, (3) mcp-tool-context.ts GlobalMCPToolProvider during FSM tool fetch. Each creates its own platform config independently. Should this be unified?"

open_question "Tool filtering happens at multiple levels with different mechanisms: (1) per-server allow/deny in MCPServerConfig, (2) platform-level tool_policy in AtlasToolsConfigSchema (allowlist/denylist), (3) FSM PLATFORM_TOOL_ALLOWLIST hardcoded constant, (4) MCPServerRegistry deny-list concatenation during merge. Are these intentionally layered or accidental duplication?"

open_question "Connection verification for stdio (10 retries, 500ms apart) and HTTP (3 retries, exponential backoff) use completely different strategies. HTTP registration also has its own retry (connectHttpWithRetry) separate from verification. Should these be unified into a single retry policy per transport type?"

open_question "The platform tools fetch during registry initialization creates a throwaway MCP Client (from @modelcontextprotocol/sdk) to list tools, while tool fetching during execution uses the AI SDK client (from @ai-sdk/mcp). These are different MCP client implementations. Is there a reason they can't use the same one?"

open_question "Agent-level MCP server overrides (AgentConfig.mcp_server_overrides with tools and timeout_ms) exist in the registry types but the actual agent context builder uses a flat merge (agent servers override workspace servers entirely). The granular override mechanism appears unused."

open_question "MCPServerRegistry.getAllPlatformTools catches errors internally and returns empty array, then getAllPlatformToolsWithRetry also catches and returns empty array. The double-catch means the retry loop never actually retries on most errors since the inner function swallows them."

open_question "The PooledMCPManager config key is generated from sorted server IDs only, ignoring config differences. Two pools with same server IDs but different transport configs, auth, or env would collide on the same key."
