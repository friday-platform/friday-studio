// Agent Orchestration
// Behavioral specification for Atlas agent lifecycle: registration, discovery,
// dispatch, execution, tool access, and result contracts.
//
// Scope: agent-sdk, agent-loader, agent-orchestrator, agent-server, agent-context,
// bundled-agents, system agents, mcp-registry, agent-helpers.

// =============================================================================
// ENTITIES
// =============================================================================

// An agent is a unit of work execution. All agents share the AtlasAgent
// interface regardless of source, but their origins and capabilities differ.
entity Agent {
  id: AgentId,                          // lowercase-with-hyphens, validated by regex
  version: SemVer,
  description: string,
  display_name: string | null,
  constraints: string | null,           // human-readable limitations
  expertise: AgentExpertise,
  source: system | bundled | sdk,       // where the agent was loaded from
  input_schema: JsonSchema | null,
  output_schema: JsonSchema | null,
  environment_config: AgentEnvironmentConfig | null,
  mcp_config: Record<ServerId, MCPServerConfig> | null,
  llm_config: AgentLLMConfig | null,
  use_workspace_skills: bool,           // whether to load workspace skills into context
}

value AgentExpertise {
  domains: string[],                    // min 1; used for discovery and matching
  examples: string[],                   // example prompts for users
}

value AgentEnvironmentConfig {
  required: EnvVarSpec[],
  optional: OptionalEnvVarSpec[],
}

value EnvVarSpec {
  name: string,
  description: string,
  validation: RegexPattern | null,
  link_ref: LinkCredentialRef | null,   // automatic credential resolution
}

value AgentLLMConfig {
  provider: anthropic | openai | google | null,
  model: string | null,
  temperature: float | null,            // 0..2
  max_tokens: int | null,
}

// The orchestrator manages agent dispatch across two execution modes.
entity AgentOrchestrator {
  mcp_sessions: Map<SessionId, MCPSession>,
  wrapped_agents: Map<AgentId, Agent>,
  active_stream_handlers: Map<StreamHandlerKey, StreamCallback>,
  active_executions: Map<ExecutionKey, ActiveExecution>,
  status: idle | running | shutdown,
}

value MCPSession {
  client: MCPClient,
  transport: StreamableHTTPTransport,
  last_activity: Timestamp,
  workspace_id: WorkspaceId | null,
}

value ActiveExecution {
  agent_id: AgentId,
  session_id: SessionId,
  start_time: Timestamp,
}

// The registry manages agent discovery across multiple adapter sources.
entity AgentRegistry {
  registered_agents: Map<AgentId, Agent>,
  agent_source_types: Map<AgentId, AgentSourceType>,
  include_system_agents: bool,
  initialized: bool,
}

// Agent execution context - built before each agent invocation.
value AgentContext {
  tools: Record<ToolName, Tool>,
  session: AgentSessionData,
  env: Record<string, string>,
  config: Record<string, unknown> | null,
  stream: StreamEmitter | null,
  logger: Logger,
  abort_signal: AbortSignal | null,
  telemetry: TelemetryConfig | null,
}

value AgentSessionData {
  session_id: SessionId,
  workspace_id: WorkspaceId,
  user_id: UserId | null,
  stream_id: StreamId | null,
  datetime: DatetimeContext | null,
}

// =============================================================================
// AGENT SOURCE TYPES (Adapter Pattern)
// =============================================================================

// Three source types, loaded by different adapters in priority order.
// All produce the same AtlasAgent interface.

config AgentSourceType { type: system | bundled | sdk }

// System agents: embedded in binary, restricted to system workspaces only.
// Currently only: conversation agent.
// Registered by SystemAgentAdapter when includeSystemAgents=true.
config SystemAgentSource {
  adapter: system-agent-adapter,
  visibility: system_workspaces_only,
}

// Bundled agents: compiled into Atlas, available to all workspaces.
// Pre-registered at adapter construction from the bundledAgents array.
// Examples: slack, google-calendar, web-search, summary, email, etc.
config BundledAgentSource {
  adapter: bundled-agent-adapter,
  visibility: all_workspaces,
}

// SDK agents: registered programmatically at runtime by application code.
config SDKAgentSource {
  adapter: sdk-agent-adapter,
  visibility: all_workspaces,
}

// =============================================================================
// WORKSPACE AGENT CONFIGURATION (workspace.yml)
// =============================================================================

// Workspace configs define agents via a discriminated union on `type`.
// Three config types, each converted differently at runtime.

// type: "llm" - ad-hoc LLM agent defined inline in workspace.yml
// Converted to AtlasAgent at runtime via convertLLMToAgent.
value LLMAgentConfig {
  type: llm,
  description: string,
  provider: string,                     // e.g., "anthropic"
  model: string,                        // e.g., "claude-sonnet-4-5"
  prompt: string,                       // system prompt
  temperature: float,                   // 0..0.7, default 0.3
  max_tokens: int | null,
  max_steps: int | null,                // multi-step tool calling limit
  tool_choice: auto | required | none,
  tools: string[] | null,               // available tool names
  max_retries: int | null,
  timeout: Duration | null,
}

// type: "system" - reference to a system agent by ID
value SystemAgentConfig {
  type: system,
  description: string,
  agent: AgentId,                       // system agent identifier
  config: SystemAgentConfigObject | null,
}

// type: "atlas" - reference to a bundled/SDK agent with customization
value AtlasAgentConfig {
  type: atlas,
  agent: AgentId,                       // registry agent ID
  description: string,
  prompt: string,                       // custom prompt prepended to input
  config: Record<string, unknown> | null,
  env: Record<string, string | LinkCredentialRef> | null,
}

// =============================================================================
// AGENT RESULTS (Discriminated Union on `ok`)
// =============================================================================

// Handler returns AgentPayload (ok/err). Execution layer wraps with metadata.
// The final AgentResult is a discriminated union on `ok`.

value AgentPayloadSuccess<T> {
  ok: true,
  data: T,
  reasoning: string | null,
  tool_calls: ToolCall[] | null,
  tool_results: ToolResult[] | null,
  artifact_refs: ArtifactRef[] | null,
  outline_refs: OutlineRef[] | null,
}

value AgentPayloadError {
  ok: false,
  error: { reason: string },
}

// Full result envelope - produced by execution layer wrapping AgentPayload.
value AgentResult {
  agent_id: AgentId,
  timestamp: ISO8601,
  input: unknown,
  duration_ms: int,
  // Discriminated on `ok`:
  ok: bool,
  // When ok=true:
  data: unknown | null,
  reasoning: string | null,
  tool_calls: ToolCall[] | null,
  tool_results: ToolResult[] | null,
  artifact_refs: ArtifactRef[] | null,
  outline_refs: OutlineRef[] | null,
  // When ok=false:
  error: { reason: string } | null,
}

// =============================================================================
// MCP REGISTRY (Tool/Integration Discovery)
// =============================================================================

entity MCPServersRegistry {
  servers: Record<ServerId, MCPServerMetadata>,
  version: string,
}

value MCPServerMetadata {
  id: ServerId,
  name: string,
  domains: string[],                    // semantic keywords for matching
  url_domains: string[] | null,         // URL-to-MCP mapping
  description: string | null,
  constraints: string | null,
  security_rating: high | medium | low | unverified,
  source: agents | static | web,
  config_template: MCPServerConfig,
  required_config: RequiredConfigField[] | null,
}

// =============================================================================
// RULES
// =============================================================================

// --- Registry Initialization ---

rule RegistryInitialization {
  when: Initialize(),
  requires: registry.initialized == false,
  ensures: {
    // Adapters are set up in this order:
    // 1. SystemAgentAdapter (only if include_system_agents)
    // 2. BundledAgentAdapter (always)
    // 3. SDKAgentAdapter (always)
    // All agents from all adapters are loaded into registered_agents.
    // First adapter to provide an agent ID wins (deduplication by ID).
    registry.initialized == true,
    registry.registered_agents contains all discoverable agents,
  }
}

rule AgentLoaderResolution {
  when: LoadAgent(agent_id),
  requires: at least one adapter is registered,
  ensures: {
    // Adapters are tried in registration order until one succeeds.
    // Cache checked first if enabled (LRU with max_cache_size=100).
    // AgentNotFoundError from one adapter causes fallthrough to next.
    // If all adapters fail, throws aggregate error.
    result is AtlasAgent,
  }
}

// --- Agent Discovery ---

rule DiscoverAgentsViaMCP {
  when: DiscoverAgents(),
  ensures: {
    // 1. Creates ephemeral MCP session for discovery
    // 2. Queries MCP server for agent:// resources
    // 3. Parses metadata from resource URI and metadata fields
    // 4. Falls back to wrapped agents if MCP fails
    // 5. Returns empty array if both paths fail
    // 6. Always cleans up discovery session
    result is AgentMetadata[],
  }
}

rule ExpertiseMatching {
  when: MatchBundledAgents(needs),
  ensures: {
    // Case-insensitive exact match of needs against agent capabilities.
    // An agent matches if ANY of its capabilities matches ANY need.
    // Returns BundledAgentMatch[] with matched capabilities and required config.
    result is BundledAgentMatch[],
  }
}

rule MCPServerMatching {
  when: MapNeedToMCPServers(need),
  ensures: {
    // Three-tier matching on domains:
    // 1. Exact match (highest priority)
    // 2. Domain contains need (if need >= 3 chars)
    // 3. Need contains domain (if domain >= 3 chars)
    // Merges static registry with dynamic servers (static takes precedence on ID collision).
    // Built-in capabilities (files, bash, csv, etc.) are excluded from unmatched detection.
    result is MCPServerMatch[],
  }
}

// --- Agent Dispatch ---

rule AgentDispatch {
  when: ExecuteAgent(agent_id, prompt, execution_context),
  ensures: {
    // Routing decision: wrapped agent (in-process) vs MCP agent (remote).
    // 1. Check wrappedAgents map first. If found, execute in-process.
    // 2. Otherwise, create/reuse MCP session and call as MCP tool.
    // Both paths produce the same AgentResult shape.
    // Active execution is tracked for workspace shutdown protection.
    // Stream handlers are registered if streamId + onStreamEvent provided.
    result is AgentResult,
  }
}

rule WrappedAgentExecution {
  when: agent_id in orchestrator.wrapped_agents,
  requires: ExecuteAgent triggered,
  ensures: {
    // 1. Build stream emitter from context callback (if streaming)
    // 2. Build agent context via createAgentContextBuilder (if available):
    //    a. Fetch MCP tools (workspace + agent + platform servers merged)
    //    b. Validate environment variables
    //    c. Load workspace skills (if agent.use_workspace_skills)
    //    d. Create stream emitter
    // 3. Falls back to empty tools if context builder unavailable
    // 4. Execute with retry: 11 attempts, 1s-30s exponential backoff with jitter
    // 5. Wrap AgentPayload with metadata (agentId, timestamp, input, durationMs)
    // On error: return AgentExecutionError (never throws)
    result is AgentResult,
  }
}

rule MCPAgentExecution {
  when: agent_id not in orchestrator.wrapped_agents,
  requires: ExecuteAgent triggered,
  ensures: {
    // 1. Get or create MCP session for the session ID
    // 2. Register abort signal handler for cancellation notification
    // 3. Call agent as MCP tool with timeout 1,200,000ms (20 min)
    // 4. Parse MCP response: unwrap content[0].text -> JSON -> MCPExecutionResult
    // 5. Validate result against AgentResultSchema
    // On error: return AgentExecutionError (never throws)
    result is AgentResult,
  }
}

// --- Tool Access ---

rule ToolMerging {
  when: BuildAgentContext(agent, session_data),
  ensures: {
    // Tool sources merged with precedence: agent MCP > platform > workspace.
    // 1. Fetch workspace config from daemon
    // 2. Start with workspace MCP servers (lowest priority)
    // 3. Add atlas-platform server (daemon /mcp endpoint)
    // 4. Agent MCP servers override workspace servers on ID collision
    // 5. Get pooled MCP manager and fetch all tools
    tools_precedence is agent_mcp > platform > workspace_mcp,
  }
}

rule ToolFiltering {
  when: LLMAgentExecution(config),
  ensures: {
    // LLM agents (type: "llm" in workspace.yml) have platform management tools denied:
    // workspace_list, workspace_delete, workspace_describe, workspace_set_persistence,
    // session_describe, session_cancel, workspace_jobs_list, workspace_jobs_describe,
    // workspace_job_execute, workspace_signals_list, workspace_agents_list,
    // workspace_agents_describe, system_version.
    // All MCP server tools and library/artifact/file tools are retained.
    filtered_tools excludes DENIED_TOOL_NAMES,
  }
}

rule ConversationAgentToolAllowlist {
  when: ConversationAgentExecution(),
  ensures: {
    // Conversation agent uses an ALLOW list (opposite of LLM agent DENY list).
    // Only exposes: workspace management, session inspection, signal triggering,
    // library, artifacts, system_version, connect_mcp_server.
    // Also registers workspace-planner and fsm-workspace-creator as direct tools.
    // Also adds: do_task, load_skill, connect_service, conversation tools.
    tools filtered by ALLOWED_TOOLS allowlist,
  }
}

// --- Agent Output Validation ---

rule AgentOutputValidation {
  when: ValidateAgentOutput(result, context, expected_schema, supervision_level, agent_type),
  requires: result.ok == true AND result.data is not empty,
  ensures: {
    // 1. Hallucination detection: ONLY for agent_type == "llm"
    //    - System agents and SDK agents are code-based, skip hallucination check
    //    - Severe hallucination (confidence < 0.3 or severe patterns) throws error
    // 2. Schema validation: if expected_schema provided, validate against JSON Schema
    // 3. Document reference check: extract referenced doc IDs from output,
    //    throw if any reference non-existent documents in context
    validation passes or throws Error,
  }
}

// --- Prompt Building ---

rule PromptPrecedence {
  when: BuildFinalAgentPrompt(action_prompt, agent_config_prompt, document_context),
  ensures: {
    // Precedence: action_prompt > agent_config_prompt > context only.
    // Task prompt (action or config) is prepended to document context.
    // If no task prompt exists, document context is used alone.
    prompt is (action_prompt || agent_config_prompt) + document_context,
  }
}

rule PromptExtractionByType {
  when: ExtractAgentConfigPrompt(agent_config),
  ensures: {
    // LLM: config.prompt (required)
    // Atlas: prompt (required)
    // System: config.prompt (optional)
    // None: empty string
    result is string,
  }
}

// --- Session Lifecycle ---

rule MCPSessionCreation {
  when: GetOrCreateSessionClient(session_id),
  requires: session not in mcp_sessions,
  ensures: {
    // 1. Create MCP Client with StreamableHTTP transport
    // 2. Connect to agents server URL with session ID header
    // 3. Register notification handler for streaming content
    // 4. Store under orchestrator session ID
    // 5. If MCP assigns different session ID, store under both keys
    // 6. Verify connection with listTools()
    new session in mcp_sessions,
  }
}

rule MCPSessionCleanup {
  when: CleanupInterval (every 300,000ms),
  ensures: {
    // Sessions inactive > 30 minutes are closed and removed.
    // Associated stream handlers are also cleaned up.
    inactive_sessions removed from mcp_sessions,
  }
}

rule OrchestratorShutdown {
  when: Shutdown(),
  ensures: {
    // 1. Clear cleanup interval
    // 2. Close all MCP transports
    // 3. Clear sessions, stream handlers
    orchestrator.status becomes shutdown,
  }
}

// --- Atlas Agent Wrapping ---

rule AtlasAgentWrapping {
  when: WrapAtlasAgent(base_agent, wrapper_id, custom_prompt, custom_env),
  ensures: {
    // Creates a new agent that:
    // 1. Prepends custom_prompt to user prompt
    // 2. Merges resolved string env vars with context env
    // 3. Delegates execution to base agent
    // Link credential refs in custom_env are filtered out (should be resolved earlier)
    result is AtlasAgent with custom prompt and env,
  }
}

// --- Error Handling ---

rule AgentExecutionErrorRecovery {
  when: ExecuteAgent fails,
  ensures: {
    // Both wrapped and MCP paths catch all errors and return AgentExecutionError.
    // The orchestrator never throws from executeAgent.
    // Error message is user-friendly via getErrorDisplayMessage.
    result.ok == false AND result.error.reason is set,
  }
}

rule WrappedAgentInternalErrorHandling {
  when: agent.execute() throws,
  ensures: {
    // AbortError (DOMException) propagates for cancellation.
    // All other errors are caught and returned as err(stringifiedError).
    // Execution layer then wraps with metadata.
    abort_errors propagate; all_others return err(),
  }
}

rule MCPResponseParsing {
  when: ParseAgentResponse(mcp_tool_result),
  ensures: {
    // 1. Validate against MCPToolResultSchema (content[0].type == "text")
    // 2. Parse text as JSON
    // 3. Handle special types: "error" throws, "cancelled" returns completed
    // 4. Validate against MCPExecutionResultSchema
    // 5. Legacy format: "No output generated" message treated as cancellation
    result is MCPExecutionResult,
  }
}

// =============================================================================
// OPEN QUESTIONS
// =============================================================================

open_question "AgentExecutionContext.agentTools field is defined but never consumed anywhere in the codebase. Is this dead code or an incomplete feature for per-agent tool filtering?"

open_question "The retry policy differs between execution paths: wrapped agents retry 11 times with exponential backoff (1s-30s), while MCP agents have no retry at the orchestrator level (only a 20-minute timeout). LLM agents converted from workspace.yml have their own retry via AI SDK (default 3). Is the 11-attempt retry for wrapped agents intentional or excessive?"

open_question "AgentExpertise in the SDK schema requires a domains array (min 1) and examples array. But during MCP discovery, the expertise is parsed from resource metadata with fallback to empty arrays for both fields, violating the min(1) constraint on domains. Should MCP-discovered agents have a default domain?"

open_question "The conversation agent builds AgentContext for direct-invoked sub-agents (workspace-planner, fsm-workspace-creator) with empty tools: {}. These sub-agents then run without tool access. Is this intentional or should they inherit the conversation agent's tools?"

open_question "Hallucination detection in validateAgentOutput only runs for agent_type == 'llm', but the agent_type parameter is an optional string that must be passed by the caller. There is no automatic derivation of agent type from the agent itself. If the caller omits it, hallucination detection is silently skipped for LLM agents too."

open_question "The MCP response parsing uses ts-expect-error comments and untyped JSON parsing for the error/cancelled/completed discrimination. The TODO comment says 'Replace with proper agent result schema once agents produce structured output.' Is there a plan to unify the MCP result format with AgentResultSchema?"

open_question "Tool filtering uses opposite strategies: LLM agents use a DENY list (filterWorkspaceAgentTools), conversation agent uses an ALLOW list. These are not composable and must be maintained separately. If a new platform tool is added, it is denied for LLM agents only if manually added to DENIED_TOOL_NAMES, but automatically excluded from conversation agent unless manually added to ALLOWED_TOOLS."

open_question "The AgentOrchestrator has a workspace_id concept threaded through (MCPSession.workspace_id, AgentExecutionContext.workspaceId) but the wrapped agent path does not use workspace_id for session isolation. Two workspaces executing the same wrapped agent could theoretically share state through the agent instance."
